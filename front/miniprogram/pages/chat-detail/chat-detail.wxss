/* Layout layer */
.chat-detail-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.record-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 22rpx;
}

.record-toolbar-title {
  max-width: 420rpx;
  font-size: 27rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.record-toolbar-sub {
  font-size: 21rpx;
}

.record-list {
  flex: 1;
  overflow-y: auto;
  padding: 14rpx 12rpx;
}

.record-board {
  box-shadow: 0 1rpx 2rpx rgba(28, 45, 69, 0.18);
}

.record-item {
  display: flex;
  flex-direction: column;
}

.record-divider {
  padding: 12rpx 0 8rpx;
  text-align: center;
}

.record-divider-text {
  display: inline-block;
  padding: 4rpx 14rpx;
  font-size: 21rpx;
}

.record-row {
  display: flex;
  align-items: flex-start;
  min-height: 92rpx;
  padding: 12rpx 14rpx;
}

.record-role {
  width: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.record-avatar {
  background: #ffffff;
}

.record-role-tag {
  margin-top: 6rpx;
  font-size: 19rpx;
}

.record-body {
  flex: 1;
  min-width: 0;
  margin-left: 10rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid;
}

.record-meta {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.record-name {
  font-size: 24rpx;
}

.record-text {
  font-size: 26rpx;
  line-height: 1.5;
  word-break: break-all;
}

.composer-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 14rpx 16rpx;
}

.composer-label {
  width: 66rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.composer-input {
  flex: 1;
}

.composer-send {
  flex-shrink: 0;
}

/* Skin layer: Retro Blue */
.theme-retro-blue {
  background: #dce4ef;
  color: #24384c;
}

.theme-retro-blue .record-toolbar {
  border-top: 1rpx solid #f4f8ff;
  border-bottom: 1rpx solid #8b99ae;
  background: linear-gradient(180deg, #f4f8ff 0%, #cfd8e8 100%);
}

.theme-retro-blue .record-toolbar-sub {
  color: #60738a;
}

.theme-retro-blue .record-board {
  border: 1rpx solid #8594a7;
  background: #eff4fb;
}

.theme-retro-blue .record-divider-text {
  border: 1rpx solid #a8b5c8;
  background: #e3ebf8;
  color: #576b85;
}

.theme-retro-blue .record-row {
  border-top: 1rpx solid #ffffff;
  border-bottom: 1rpx solid #c7d1df;
}

.theme-retro-blue .record-peer {
  background: #f9fbff;
}

.theme-retro-blue .record-self {
  background: #edf3fc;
}

.theme-retro-blue .record-avatar {
  border: 1rpx solid #8998ad;
}

.theme-retro-blue .record-role-tag {
  color: #62758d;
}

.theme-retro-blue .record-peer .record-body {
  border-left-color: #9aa9bd;
}

.theme-retro-blue .record-self .record-body {
  border-left-color: #6f8fb9;
}

.theme-retro-blue .record-name {
  color: #2b4258;
}

.theme-retro-blue .record-name-self {
  color: #2f4f79;
}

.theme-retro-blue .record-text {
  color: #1d2f42;
}

.theme-retro-blue .composer-bar {
  border-top: 1rpx solid #8d9bad;
  background: linear-gradient(180deg, #eaf0f9 0%, #c7d2e4 100%);
}

.theme-retro-blue .composer-label {
  border: 1rpx solid #8b99ad;
  background: #f3f7fe;
  color: #50637d;
}

