@import "../../styles/im-runtime-tip.wxss";
@import "../../styles/im-chat-common.wxss";

.im-page {
  --im-message-list-top: 82rpx;
}

.im-header {
  position: relative;
  z-index: 10;
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 14rpx;
  border-top: 1rpx solid var(--retro-toolbar-top-border);
  border-bottom: 1rpx solid var(--retro-toolbar-border);
  background: var(--retro-toolbar-bg);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.im-header-main {
  min-width: 0;
  display: flex;
  align-items: center;
  flex: 1;
}

.im-header-avatar {
  border: 1rpx solid var(--retro-avatar-border);
}

.im-header-meta {
  min-width: 0;
  margin-left: 12rpx;
}

.im-header-name-line {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 6rpx;
}

.im-header-title-badge {
  max-width: 140rpx;
}

.im-header-name {
  display: block;
  min-width: 0;
  flex: 1;
  max-width: 410rpx;
  font-size: 29rpx;
  font-weight: 600;
  color: var(--retro-strong-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.im-header-actions {
  margin-left: 12rpx;
}

.im-header-action {
  font-size: 22rpx;
  color: var(--retro-muted-text-2);
}
