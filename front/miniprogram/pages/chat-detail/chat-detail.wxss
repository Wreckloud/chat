.im-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.im-header {
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 14rpx;
  border-top: 1rpx solid var(--retro-toolbar-top-border);
  border-bottom: 1rpx solid var(--retro-toolbar-border);
  background: var(--retro-toolbar-bg);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.im-header-main {
  min-width: 0;
  display: flex;
  align-items: center;
  flex: 1;
}

.im-header-avatar {
  border: 1rpx solid var(--retro-avatar-border);
}

.im-header-meta {
  min-width: 0;
  margin-left: 12rpx;
}

.im-header-name {
  display: block;
  max-width: 410rpx;
  font-size: 29rpx;
  font-weight: 600;
  color: var(--retro-strong-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.im-header-actions {
  margin-left: 12rpx;
}

.im-header-action {
  font-size: 22rpx;
  color: var(--retro-muted-text-2);
}

.im-message-list {
  flex: 1;
  overflow-y: auto;
  box-sizing: border-box;
  padding: 10rpx 12rpx 0;
}

.im-state-text {
  margin-top: 80rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--retro-muted-text);
}

.im-message-stream {
  padding-bottom: 12rpx;
}

.im-divider {
  margin: 14rpx 0 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.im-divider-line {
  flex: 1;
  height: 1rpx;
  background: var(--retro-tab-divider);
}

.im-divider-text {
  flex-shrink: 0;
  font-size: 19rpx;
  color: var(--retro-muted-text);
}

.im-group {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.im-group-self {
  flex-direction: row-reverse;
}

.im-avatar-col {
  width: 74rpx;
  flex-shrink: 0;
}

.im-group-self .im-avatar-col {
  display: flex;
  justify-content: flex-end;
}

.im-avatar {
  border: 1rpx solid var(--retro-avatar-border);
}

.im-message-col {
  flex: 0 1 auto;
  min-width: 0;
  max-width: 560rpx;
  margin-left: 10rpx;
  display: flex;
  flex-direction: column;
}

.im-group-self .im-message-col {
  margin-left: 0;
  margin-right: 10rpx;
  align-items: flex-end;
}

.im-meta-col {
  width: 100%;
  height: 74rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: stretch;
  align-items: flex-start;
}

.im-name-line {
  height: 56rpx;
  width: 100%;
  display: flex;
  align-items: center;
}

.im-time-line {
  height: 18rpx;
  width: 100%;
  display: flex;
  align-items: flex-start;
}

.im-name {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  max-width: 360rpx;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.im-name-peer {
  color: var(--retro-link-text);
}

.im-name-self {
  color: var(--retro-record-name-self);
  justify-content: flex-end;
  text-align: right;
}

.im-meta-time {
  width: 100%;
  font-size: 20rpx;
  line-height: 1.2;
  color: var(--retro-muted-text);
}

.im-group-self .im-meta-col {
  align-items: flex-end;
  text-align: right;
}

.im-group-self .im-name-line,
.im-group-self .im-time-line {
  justify-content: flex-end;
}

.im-line {
  margin-top: 5rpx;
}

.im-line:first-of-type {
  margin-top: 3rpx;
}

.im-group-self .im-line {
  display: flex;
  justify-content: flex-end;
}

.im-text {
  display: block;
  max-width: 500rpx;
  font-size: 27rpx;
  line-height: 1.5;
  color: var(--retro-record-text);
  word-break: break-all;
}

.im-composer {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 12rpx calc(10rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--retro-composer-border);
  background: var(--retro-composer-bg);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
}

.im-composer-input {
  flex: 1;
  height: 64rpx;
  box-sizing: border-box;
  padding: 0 18rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: #ffffff;
  color: var(--retro-page-text);
  font-size: 25rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.82);
}

.im-composer-input-placeholder {
  color: var(--retro-muted-text);
}

.im-composer-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.im-more-btn {
  min-width: 92rpx;
}

.im-send-btn {
  min-width: 92rpx;
}
