@import "../../styles/im-chat-common.wxss";
@import "../../styles/topbar.wxss";

.im-page {
  --im-message-list-top: 88rpx;
}

.im-header {
  position: relative;
  z-index: 10;
}

.im-header-main {
  min-width: 0;
  display: flex;
  align-items: center;
  flex: 1;
}

.im-header-meta {
  min-width: 0;
}

.im-header-title-badge {
  max-width: 140rpx;
}

.im-header-name {
  display: block;
}

.im-header-actions {
  margin-left: 12rpx;
}

.im-header-action {
  font-size: 22rpx;
  color: var(--retro-muted-text-2);
}
