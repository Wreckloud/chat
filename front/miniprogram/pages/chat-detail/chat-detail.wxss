/* Layout layer */
.chat-detail-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.record-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 22rpx;
  border-top: 1rpx solid var(--retro-toolbar-top-border);
  border-bottom: 1rpx solid var(--retro-toolbar-border);
  background: var(--retro-toolbar-bg);
}

.record-toolbar-title {
  max-width: 420rpx;
  font-size: 27rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.record-toolbar-sub {
  font-size: 21rpx;
  color: var(--retro-toolbar-sub-text);
}

.record-list {
  flex: 1;
  overflow-y: auto;
  padding: 14rpx 12rpx;
}

.record-board {
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.record-item {
  display: flex;
  flex-direction: column;
}

.record-divider {
  padding: 12rpx 0 8rpx;
  text-align: center;
}

.record-divider-text {
  display: inline-block;
  padding: 4rpx 14rpx;
  font-size: 21rpx;
  border: 1rpx solid var(--retro-divider-border);
  background: var(--retro-divider-bg);
  color: var(--retro-divider-text);
}

.record-row {
  display: flex;
  align-items: flex-start;
  min-height: 92rpx;
  padding: 12rpx 14rpx;
  border-top: 1rpx solid #ffffff;
  border-bottom: 1rpx solid var(--retro-row-border);
}

.record-peer {
  background: var(--retro-record-peer-bg);
}

.record-self {
  background: var(--retro-record-self-bg);
}

.record-role {
  width: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.record-avatar {
  border: 1rpx solid var(--retro-avatar-border);
  background: #ffffff;
}

.record-role-tag {
  margin-top: 6rpx;
  font-size: 19rpx;
  color: var(--retro-muted-text);
}

.record-body {
  flex: 1;
  min-width: 0;
  margin-left: 10rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid;
}

.record-peer .record-body {
  border-left-color: var(--retro-record-peer-line);
}

.record-self .record-body {
  border-left-color: var(--retro-record-self-line);
}

.record-meta {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.record-name {
  font-size: 24rpx;
  color: var(--retro-record-name);
}

.record-name-self {
  color: var(--retro-record-name-self);
}

.record-text {
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--retro-record-text);
  word-break: break-all;
}

.composer-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 14rpx 16rpx;
  border-top: 1rpx solid var(--retro-composer-border);
  background: var(--retro-composer-bg);
}

.composer-label {
  width: 66rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  border: 1rpx solid var(--retro-composer-label-border);
  background: var(--retro-composer-label-bg);
  color: var(--retro-composer-label-text);
}

.composer-input {
  flex: 1;
}

.composer-send {
  flex-shrink: 0;
}
