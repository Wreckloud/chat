<view class="im-page {{themeClass}}">
  <view class="im-header">
    <view class="im-header-main" catchtap="goUserProfile">
      <retro-avatar
        class="im-header-avatar"
        size="medium"
        shape="square"
        image="{{targetUser.avatar}}">
        {{targetUser.nickname ? targetUser.nickname.charAt(0) : '行'}}
      </retro-avatar>
      <view class="im-header-meta">
        <text class="im-header-name">{{targetUser.nickname || targetUser.wolfNo || '聊天会话'}}</text>
      </view>
    </view>
    <view class="im-header-actions">
      <text class="im-header-action">会话</text>
    </view>
  </view>

  <scroll-view
    id="message-list"
    class="im-message-list"
    style="bottom: {{messageListBottomPx}}px;"
    scroll-y
    scroll-into-view="{{scrollIntoView}}"
    upper-threshold="80"
    bindscrolltoupper="onMessageListUpper"
    enable-back-to-top>
    <view wx:if="{{loading && messages.length === 0}}" class="im-state-text">加载中...</view>

    <view wx:elif="{{messages.length === 0}}" class="im-state-text">暂无消息</view>

    <view wx:else class="im-message-stream">
      <block wx:for="{{messageBlocks}}" wx:key="key" wx:for-item="blockItem">
        <view wx:if="{{blockItem.type === 'divider'}}" class="im-divider">
          <view class="im-divider-line"></view>
          <text class="im-divider-text">{{blockItem.timeText}}</text>
          <view class="im-divider-line"></view>
        </view>

        <view wx:elif="{{blockItem.type === 'group'}}" class="im-group {{blockItem.isSelf ? 'im-group-self' : ''}}">
          <retro-avatar
            class="im-avatar"
            size="medium"
            shape="square"
            image="{{blockItem.senderAvatar}}"
            data-user-id="{{blockItem.senderId}}"
            bindtap="onTapUserElement">
            {{blockItem.senderInitial}}
          </retro-avatar>

          <view class="im-message-col">
            <view class="im-meta-col">
              <view class="im-name-line">
                <view
                  class="im-name {{blockItem.isSelf ? 'im-name-self' : 'im-name-peer'}}"
                  data-user-id="{{blockItem.senderId}}"
                  bindtap="onTapUserElement">
                  {{blockItem.senderName}}
                </view>
              </view>
              <view class="im-time-line">
                <view class="im-meta-time">{{blockItem.headerTimeText}}</view>
              </view>
            </view>

            <view wx:for="{{blockItem.rows}}" wx:key="key" wx:for-item="lineItem" class="im-line">
              <image
                wx:if="{{lineItem.msgType === 'IMAGE' && lineItem.mediaUrl}}"
                class="im-image"
                src="{{lineItem.mediaUrl}}"
                mode="widthFix"
                data-url="{{lineItem.mediaUrl}}"
                bindtap="previewImage" />
              <video
                wx:elif="{{lineItem.msgType === 'VIDEO' && lineItem.mediaUrl}}"
                class="im-video"
                src="{{lineItem.mediaUrl}}"
                object-fit="contain"
                controls
                show-center-play-btn="{{true}}"
                show-fullscreen-btn="{{true}}" />
              <text
                wx:elif="{{lineItem.msgType === 'FILE' && lineItem.mediaUrl}}"
                class="im-text im-file"
                data-url="{{lineItem.mediaUrl}}"
                data-name="{{lineItem.content}}"
                bindtap="onTapFile">
                {{lineItem.fileLabel}}
              </text>
              <text
                wx:elif="{{lineItem.msgType === 'TEXT' && lineItem.linkUrl}}"
                class="im-text im-link"
                data-url="{{lineItem.linkUrl}}"
                bindtap="onTapLink">
                {{lineItem.content}}
              </text>
              <text wx:elif="{{lineItem.msgType === 'TEXT'}}" class="im-text">{{lineItem.content}}</text>
              <text wx:else class="im-media-missing">[媒体不可用]</text>
            </view>
          </view>
        </view>
      </block>
      <view id="im-bottom-anchor" class="im-bottom-anchor"></view>
    </view>
  </scroll-view>

  <view id="im-dock" class="im-dock" style="bottom: {{keyboardHeightPx}}px;">
    <view id="im-composer" class="im-composer {{morePanelVisible ? 'is-panel-open' : ''}}">
      <input
        class="im-composer-input"
        type="text"
        placeholder="输入消息..."
        placeholder-class="im-composer-input-placeholder"
        value="{{inputMessage}}"
        adjust-position="{{false}}"
        hold-keyboard="{{true}}"
        confirm-hold="{{true}}"
        bindkeyboardheightchange="onKeyboardHeightChange"
        bindfocus="onComposerFocus"
        bindblur="onComposerBlur"
        bindinput="onMessageInput"
        confirm-type="send"
        bindconfirm="sendMessage"
      />

      <view class="im-composer-actions">
        <retro-button
          class="im-more-btn"
          size="medium"
          theme="default"
          disabled="{{sending}}"
          bindtap="onClickMore">
          更多
        </retro-button>
        <retro-button
          class="im-send-btn"
          size="medium"
          theme="primary"
          disabled="{{sending}}"
          loading="{{sending}}"
          bindtap="sendMessage">
          发送
        </retro-button>
      </view>
    </view>

    <view wx:if="{{morePanelVisible}}" class="im-more-panel">
      <view class="im-more-title">更多功能</view>
      <view class="im-more-grid">
        <view
          wx:for="{{moreActions}}"
          wx:key="key"
          class="im-more-item {{item.disabled ? 'is-disabled' : ''}}"
          data-key="{{item.key}}"
          bindtap="onMoreActionTap">
          <view class="im-more-item-icon">{{item.icon || '+'}}</view>
          <view class="im-more-item-label">{{item.label}}</view>
          <view wx:if="{{item.subLabel}}" class="im-more-item-sub">{{item.subLabel}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
