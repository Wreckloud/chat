<import src="../../templates/im-chat-body.wxml" />

<view class="im-page {{themeClass}}">
  <view class="im-header">
    <view class="im-header-main" catchtap="goUserProfile">
      <retro-avatar
        class="im-header-avatar"
        size="medium"
        shape="square"
        image="{{targetUser.avatar}}">
        {{targetUser.nickname ? targetUser.nickname.charAt(0) : '行'}}
      </retro-avatar>
      <view class="im-header-meta">
        <view class="im-header-name-line">
          <text
            wx:if="{{targetUser.displayTitleName}}"
            class="im-header-title-badge"
            style="{{targetUser.displayTitleColor ? 'color:' + targetUser.displayTitleColor + ';' : ''}}">
            [{{targetUser.displayTitleName}}]
          </text>
          <text class="im-header-name">{{targetUser.displayName || targetUser.nickname || targetUser.wolfNo || '聊天会话'}}</text>
        </view>
      </view>
    </view>
    <view class="im-header-actions">
      <text class="im-header-action">会话</text>
    </view>
  </view>

  <template
    is="imChatBody"
    data="{{messageListBottomPx: messageListBottomPx, scrollIntoView: scrollIntoView, loading: loading, messages: messages, messageBlocks: messageBlocks, keyboardHeightPx: keyboardHeightPx, connectionTip: connectionTip, morePanelVisible: morePanelVisible, inputMessage: inputMessage, composerFocused: composerFocused, sending: sending, canSendText: canSendText, moreActions: moreActions, emptyText: '暂无消息', inputPlaceholder: '输入消息...'}}" />
</view>
