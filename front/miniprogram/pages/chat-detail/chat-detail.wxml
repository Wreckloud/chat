<view class="chat-detail-page {{themeClass}}">
  <view class="record-toolbar">
    <view class="record-toolbar-title">{{targetUser.nickname || targetUser.wolfNo || '聊天会话'}}</view>
    <view class="record-toolbar-sub">会话记录流</view>
  </view>

  <scroll-view
    id="message-list"
    class="record-list"
    scroll-y
    scroll-top="{{scrollTop}}"
    enable-back-to-top>
    <t-loading wx:if="{{loading && messages.length === 0}}" theme="circular" size="40rpx" text="加载中..." />

    <t-empty wx:elif="{{messages.length === 0}}" description="暂无消息" />

    <view wx:else class="record-board">
      <view wx:for="{{messages}}" wx:key="messageId" class="record-item">
        <view wx:if="{{item.showTime}}" class="record-divider">
          <text class="record-divider-text">{{item.timeText}}</text>
        </view>

        <view class="record-row {{item.senderId === currentUserId ? 'record-self' : 'record-peer'}}">
          <view class="record-role">
            <t-avatar
              wx:if="{{item.senderId !== currentUserId}}"
              class="record-avatar"
              size="small"
              shape="round"
              image="{{targetUser.avatar}}"
              catchtap="goUserProfile">
              {{targetUser.nickname ? targetUser.nickname.charAt(0) : '行'}}
            </t-avatar>
            <t-avatar
              wx:else
              class="record-avatar"
              size="small"
              shape="round"
              image="{{currentUser.avatar}}">
              {{currentUser.nickname ? currentUser.nickname.charAt(0) : '我'}}
            </t-avatar>
            <text class="record-role-tag">{{item.senderId === currentUserId ? '我' : '对方'}}</text>
          </view>

          <view class="record-body">
            <view class="record-meta">
              <text
                wx:if="{{item.senderId !== currentUserId}}"
                class="record-name"
                catchtap="goUserProfile">
                {{targetUser.nickname || targetUser.wolfNo || '对方'}}
              </text>
              <text
                wx:else
                class="record-name record-name-self">
                {{currentUser.nickname || currentUser.wolfNo || '我'}}
              </text>
            </view>
            <text class="record-text">{{item.content}}</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="composer-bar">
    <view class="composer-label">发送</view>
    <t-input
      class="composer-input"
      placeholder="输入消息..."
      value="{{inputMessage}}"
      disabled="{{sending}}"
      bind:change="onMessageInput"
      bind:input="onMessageInput"
      confirm-type="send"
      bindconfirm="sendMessage"
    />
    <retro-button
      class="composer-send"
      size="small"
      theme="primary"
      disabled="{{sending}}"
      loading="{{sending}}"
      bindtap="sendMessage">
      {{sending ? '发送中' : '发送'}}
    </retro-button>
  </view>
</view>
