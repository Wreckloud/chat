<view class="im-page {{themeClass}}">
  <view class="im-header">
    <view class="im-header-main" catchtap="goUserProfile">
      <retro-avatar
        class="im-header-avatar"
        size="medium"
        shape="square"
        image="{{targetUser.avatar}}">
        {{targetUser.nickname ? targetUser.nickname.charAt(0) : '行'}}
      </retro-avatar>
      <view class="im-header-meta">
        <text class="im-header-name">{{targetUser.nickname || targetUser.wolfNo || '聊天会话'}}</text>
      </view>
    </view>
    <view class="im-header-actions">
      <text class="im-header-action">会话</text>
    </view>
  </view>

  <scroll-view
    id="message-list"
    class="im-message-list"
    scroll-y
    scroll-top="{{scrollTop}}"
    lower-threshold="60"
    bindscrolltolower="onMessageListLower"
    enable-back-to-top>
    <view wx:if="{{loading && messages.length === 0}}" class="im-state-text">加载中...</view>

    <view wx:elif="{{messages.length === 0}}" class="im-state-text">暂无消息</view>

    <view wx:else class="im-message-stream">
      <block wx:for="{{messageBlocks}}" wx:key="key" wx:for-item="blockItem">
        <view wx:if="{{blockItem.type === 'divider'}}" class="im-divider">
          <view class="im-divider-line"></view>
          <text class="im-divider-text">{{blockItem.timeText}}</text>
          <view class="im-divider-line"></view>
        </view>

        <view wx:elif="{{blockItem.type === 'group'}}" class="im-group {{blockItem.isSelf ? 'im-group-self' : ''}}">
          <view class="im-avatar-col">
            <retro-avatar
              class="im-avatar"
              size="medium"
              shape="square"
              image="{{blockItem.senderAvatar}}"
              data-user-id="{{blockItem.senderId}}"
              bindtap="onTapUserElement">
              {{blockItem.senderInitial}}
            </retro-avatar>
          </view>

          <view class="im-message-col">
            <view class="im-meta-col">
              <view class="im-name-line">
                <view
                  class="im-name {{blockItem.isSelf ? 'im-name-self' : 'im-name-peer'}}"
                  data-user-id="{{blockItem.senderId}}"
                  bindtap="onTapUserElement">
                  {{blockItem.senderName}}
                </view>
              </view>
              <view class="im-time-line">
                <view class="im-meta-time">{{blockItem.headerTimeText}}</view>
              </view>
            </view>

            <view wx:for="{{blockItem.rows}}" wx:key="key" wx:for-item="lineItem" class="im-line">
              <text class="im-text">{{lineItem.content}}</text>
            </view>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>

  <view class="im-composer">
    <input
      class="im-composer-input"
      type="text"
      placeholder="输入消息..."
      placeholder-class="im-composer-input-placeholder"
      value="{{inputMessage}}"
      disabled="{{sending}}"
      bindinput="onMessageInput"
      confirm-type="send"
      bindconfirm="sendMessage"
    />

    <view class="im-composer-actions">
      <retro-button
        class="im-more-btn"
        size="medium"
        theme="default"
        bindtap="onClickMore">
        更多
      </retro-button>
      <retro-button
        class="im-send-btn"
        size="medium"
        theme="primary"
        disabled="{{sending}}"
        loading="{{sending}}"
        bindtap="sendMessage">
        发送
      </retro-button>
    </view>
  </view>
</view>
