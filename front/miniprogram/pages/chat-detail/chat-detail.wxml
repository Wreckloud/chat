<import src="../../templates/im-chat-body.wxml" />

<view class="im-page {{themeClass}}">
  <view class="im-header">
    <view class="im-header-main" catchtap="goUserProfile">
      <view class="im-header-meta">
        <view class="im-header-name-line u-name-line">
          <view class="im-header-name u-name">{{targetUser.displayName || targetUser.nickname || targetUser.wolfNo || '聊天会话'}}</view>
          <view
            wx:if="{{targetUser.displayTitleName}}"
            class="im-header-title-badge u-title-badge retro-title-badge retro-title-badge-md"
            style="{{targetUser.displayTitleColor ? 'color:' + targetUser.displayTitleColor + ';' : ''}}">
            [{{targetUser.displayTitleName}}]
          </view>
        </view>
      </view>
    </view>
    <view class="im-header-actions">
      <text class="im-header-action">会话</text>
    </view>
  </view>

  <template
    is="imChatBody"
    data="{{messageListBottomPx: messageListBottomPx, scrollIntoView: scrollIntoView, loading: loading, messages: messages, messageBlocks: messageBlocks, keyboardHeightPx: keyboardHeightPx, morePanelVisible: morePanelVisible, inputMessage: inputMessage, composerFocused: composerFocused, sending: sending, canSendText: canSendText, moreActions: moreActions, replyDraft: replyDraft, emptyText: '暂无消息', inputPlaceholder: '输入消息...'}}" />
</view>
