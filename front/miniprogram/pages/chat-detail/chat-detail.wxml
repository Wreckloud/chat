<view class="chat-detail-container">
  <!-- 消息列表 -->
  <scroll-view 
    id="message-list" 
    class="message-list" 
    scroll-y
    scroll-top="{{scrollTop}}"
    enable-back-to-top>
    
    <t-loading wx:if="{{loading && messages.length === 0}}" theme="circular" size="40rpx" text="加载中..." />
    
    <t-empty wx:elif="{{messages.length === 0}}" description="暂无消息" />
    
    <view wx:else class="message-wrapper">
      <view wx:for="{{messages}}" wx:key="messageId" class="message-item">
        <!-- 显示时间（间隔>5分钟） -->
        <view wx:if="{{item.showTime}}" class="message-time">
          {{item.timeText}}
        </view>
        
        <!-- 自己发送的消息（右侧） -->
        <view wx:if="{{item.senderId === currentUserId}}" class="message-row message-right">
          <view class="message-content">
            <text class="message-text">{{item.content}}</text>
          </view>
        </view>
        
        <!-- 对方发送的消息（左侧） -->
        <view wx:else class="message-row message-left">
          <t-avatar 
            class="message-avatar"
            size="small" 
            shape="round"
            image="{{targetUser.avatar}}">
            {{targetUser.nickname ? targetUser.nickname.charAt(0) : '行'}}
          </t-avatar>
          <view class="message-content-wrapper">
            <view class="message-sender">{{targetUser.nickname || targetUser.wolfNo}}</view>
            <view class="message-content">
              <text class="message-text">{{item.content}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 输入框 -->
  <view class="input-bar">
    <t-input
      class="input-field"
      placeholder="输入消息..."
      value="{{inputMessage}}"
      disabled="{{sending}}"
      bind:change="onMessageInput"
      bind:input="onMessageInput"
      confirm-type="send"
      bindconfirm="sendMessage"
    />
    <t-button 
      class="send-btn" 
      size="small" 
      theme="primary"
      disabled="{{sending}}"
      loading="{{sending}}"
      bindtap="sendMessage">
      {{sending ? '发送中' : '发送'}}
    </t-button>
  </view>
</view>