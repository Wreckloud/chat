<view class="container {{themeClass}}">
  <!-- 注册模式 -->
  <view wx:if="{{mode === 'register'}}">
    <view class="header">
      <view class="title">{{copy.register.title}}</view>
    </view>

    <!-- 显示注册结果 -->
    <view wx:if="{{showResult}}" class="result-container">
      <view class="result-list">
        <view class="result-row">
          <text class="result-label">{{copy.register.resultTitle}}</text>
          <text class="result-note">{{copy.register.resultDesc}}</text>
        </view>
        <view class="result-row">
          <text class="result-label">{{copy.register.resultNoLabel}}</text>
          <text class="result-note">{{registeredWolfNo}}</text>
        </view>
      </view>

      <retro-button
        theme="primary"
        size="large"
        block
        bindtap="handleConfirmRegister"
        class="confirm-btn">
        {{copy.register.resultConfirmButton}}
      </retro-button>
    </view>

    <!-- 注册表单 -->
    <view wx:else>
      <view class="register-card">
        <view class="form-content">
          <retro-input
            label="{{copy.register.nicknameLabel}}"
            placeholder="{{copy.register.nicknamePlaceholder}}"
            value="{{nickname}}"
            required="{{true}}"
            bind:input="onNicknameInput"
            class="form-input"
          />

          <retro-input
            label="{{copy.register.emailLabel}}"
            placeholder="{{copy.register.emailPlaceholder}}"
            value="{{email}}"
            bind:input="onEmailInput"
            class="form-input"
          />

          <retro-input
            label="{{copy.register.passwordLabel}}"
            placeholder="{{copy.register.passwordPlaceholder}}"
            type="password"
            value="{{password}}"
            hold-to-reveal="{{true}}"
            meta-level="{{passwordStrengthLevel}}"
            meta-text="{{passwordStrengthInlineText}}"
            required="{{true}}"
            bind:input="onPasswordInput"
            class="form-input"
          />

          <retro-input
            label="{{copy.register.confirmPasswordLabel}}"
            placeholder="{{copy.register.confirmPasswordPlaceholder}}"
            type="password"
            value="{{confirmPassword}}"
            hold-to-reveal="{{true}}"
            required="{{true}}"
            bind:input="onConfirmPasswordInput"
            class="form-input"
          />

          <retro-button
            theme="primary"
            size="large"
            block
            loading="{{loading}}"
            bindtap="handleRegister"
            class="register-btn">
            {{copy.register.submitButton}}
          </retro-button>

          <view class="switch-mode">
            <text class="switch-link" bindtap="switchToLogin">{{copy.register.switchToLogin}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 登录模式 -->
  <view wx:else>
    <view class="header">
      <view class="title">{{copy.login.title}}</view>
    </view>

    <view class="login-card">
      <view class="form-content">
        <retro-input
          label="{{copy.login.accountLabel}}"
          placeholder="{{copy.login.accountPlaceholder}}"
          value="{{account}}"
          bind:input="onAccountInput"
          class="form-input"
        />

        <retro-input
          label="{{copy.login.passwordLabel}}"
          placeholder="{{copy.login.passwordPlaceholder}}"
          type="password"
          value="{{loginKey}}"
          hold-to-reveal="{{true}}"
          bind:input="onLoginKeyInput"
          class="form-input"
        />

        <retro-button
          theme="primary"
          size="large"
          block
          loading="{{loading}}"
          bindtap="handleLogin"
          class="login-btn">
          {{copy.login.submitButton}}
        </retro-button>

        <view class="login-links-row">
          <text class="login-link" bindtap="goResetPassword">{{copy.login.forgotPassword}}</text>
          <text class="login-link" bindtap="switchToRegister">{{copy.login.switchToRegister}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
