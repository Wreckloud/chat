<view class="container {{themeClass}}">
  <!-- 注册模式 -->
  <view wx:if="{{mode === 'register'}}">
    <view class="header">
      <view class="title">注册</view>
    </view>

    <!-- 显示注册结果 -->
    <view wx:if="{{showResult}}" class="result-container">
      <view class="result-list">
        <view class="result-row">
          <text class="result-label">注册成功</text>
          <text class="result-note">您的行者编号</text>
        </view>
        <view class="result-row">
          <text class="result-label">行者编号</text>
          <text class="result-note">{{registeredWolfNo}}</text>
        </view>
      </view>

      <retro-button
        theme="primary"
        size="large"
        block
        bindtap="handleConfirmRegister"
        class="confirm-btn">
        进入群落
      </retro-button>
    </view>

    <!-- 注册表单 -->
    <view wx:else>
      <view class="register-card">
        <view class="form-content">
          <retro-input
            label="称谓"
            placeholder="被其他行者所记住的称呼"
            value="{{nickname}}"
            bind:input="onNicknameInput"
            bind:change="onNicknameInput"
            class="form-input"
          />

          <retro-input
            label="邮箱"
            placeholder="请输入邮箱"
            value="{{email}}"
            bind:input="onEmailInput"
            bind:change="onEmailInput"
            class="form-input"
          />

          <retro-input
            label="密码"
            placeholder="请输入密码（至少6位）"
            type="password"
            value="{{password}}"
            hold-to-reveal="{{true}}"
            meta-level="{{passwordStrengthLevel}}"
            meta-text="{{passwordStrengthInlineText}}"
            bind:input="onPasswordInput"
            bind:change="onPasswordInput"
            class="form-input"
          />

          <retro-input
            label="确认"
            placeholder="请再次输入密码"
            type="password"
            value="{{confirmPassword}}"
            hold-to-reveal="{{true}}"
            bind:input="onConfirmPasswordInput"
            bind:change="onConfirmPasswordInput"
            class="form-input"
          />

          <retro-button
            theme="primary"
            size="large"
            block
            loading="{{loading}}"
            bindtap="handleRegister"
            class="register-btn">
            注册
          </retro-button>

          <view class="switch-mode">
            <text class="switch-link" bindtap="switchToLogin">已是行者？回到群落</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 登录模式 -->
  <view wx:else>
    <view class="header">
      <view class="title">登录</view>
    </view>

    <view class="login-card">
      <view class="form-content">
        <retro-input
          label="账号"
          placeholder="请输入狼藉号或邮箱"
          value="{{account}}"
          bind:input="onAccountInput"
          bind:change="onAccountInput"
          class="form-input"
        />

        <retro-input
          label="密码"
          placeholder="请输入密码"
          type="password"
          value="{{loginKey}}"
          hold-to-reveal="{{true}}"
          bind:input="onLoginKeyInput"
          bind:change="onLoginKeyInput"
          class="form-input"
        />

        <retro-button
          theme="primary"
          size="large"
          block
          loading="{{loading}}"
          bindtap="handleLogin"
          class="login-btn">
          登录
        </retro-button>

        <view class="switch-mode">
          <text class="switch-link" bindtap="switchToRegister">还未加入？去注册</text>
        </view>
      </view>
    </view>
  </view>
</view>
