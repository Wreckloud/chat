/* Layout layer */
.container {
  min-height: 100vh;
  padding: 30rpx 24rpx;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.header {
  text-align: center;
  padding: 16rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--retro-toolbar-border);
  background: var(--retro-toolbar-bg);
}

.title {
  font-size: 46rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.result-container,
.register-card,
.login-card {
  padding: 24rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.confirm-btn,
.register-btn,
.login-btn {
  margin-top: 26rpx;
}

.result-list {
  border: 1rpx solid var(--retro-panel-border);
  background: rgba(255, 255, 255, 0.32);
}

.result-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 16rpx;
  border-bottom: 1rpx solid var(--retro-row-border, #c8d2e1);
}

.result-row:last-child {
  border-bottom: none;
}

.result-label {
  font-size: 23rpx;
  color: var(--retro-body-text, #304459);
}

.result-note {
  font-size: 23rpx;
  color: var(--retro-strong-text, #1c2b3b);
  font-weight: 600;
}

.form-content {
  padding: 6rpx 0;
}

.form-input {
  margin-bottom: 16rpx;
}

.login-links-row {
  display: flex;
  justify-content: space-between;
  margin-top: 30rpx;
}

.guest-entry {
  text-align: center;
  margin-top: 18rpx;
}

.guest-entry-link {
  font-size: 22rpx;
  color: var(--retro-link-text);
  text-decoration: underline;
}

.login-link {
  font-size: 22rpx;
  color: var(--retro-link-text);
  text-decoration: underline;
}

.switch-mode {
  text-align: center;
  margin-top: 30rpx;
}

.switch-link {
  font-size: 25rpx;
  color: var(--retro-link-text);
  text-decoration: underline;
}
