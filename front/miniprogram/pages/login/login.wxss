/* Layout layer */
.container {
  min-height: 100vh;
  padding: 30rpx 24rpx;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.header {
  text-align: center;
  padding: 16rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--retro-toolbar-border);
  background: var(--retro-toolbar-bg);
}

.title {
  font-size: 46rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.result-container,
.register-card,
.login-card {
  padding: 24rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.confirm-btn,
.register-btn,
.login-btn {
  margin-top: 26rpx;
}

.form-content {
  padding: 6rpx 0;
}

.form-input {
  margin-bottom: 16rpx;
}

.switch-mode {
  text-align: center;
  margin-top: 30rpx;
}

.switch-link {
  font-size: 25rpx;
  color: var(--retro-link-text);
  text-decoration: underline;
}
