/**
 * 登录页面样式
 */

.container {
  padding: 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.result-container {
  margin-top: 40rpx;
}


.confirm-btn {
  margin-top: 40rpx;
}

.register-form {
  margin-top: 40rpx;
}

.register-card {
  padding: 40rpx;
}

.register-btn {
  margin-top: 40rpx;
}

.login-card {
  padding: 40rpx;
  margin-top: 40rpx;
}

.form-content {
  padding: 20rpx 0;
}

.form-input {
  margin-bottom: 20rpx;
}


.login-btn {
  margin-top: 40rpx;
}

.switch-mode {
  text-align: center;
  margin-top: 40rpx;
}

.switch-link {
  font-size: 28rpx;
  text-decoration: underline;
}
