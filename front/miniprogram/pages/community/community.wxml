<view class="community-page {{themeClass}}">
  <view class="community-toolbar">
    <view class="community-title">社区论坛</view>
    <retro-button size="small" theme="primary" bindtap="goCreatePost">发帖</retro-button>
  </view>

  <retro-empty wx:if="{{posts.length === 0}}" description="暂无帖子" />

  <view wx:else class="post-board">
    <view
      wx:for="{{posts}}"
      wx:key="postId"
      class="post-row"
      bindtap="goPostDetail"
      data-id="{{item.postId}}">
      <view class="post-author" catchtap="goUserProfile" data-user="{{item.author}}">
        <retro-avatar
          class="post-avatar"
          size="small"
          shape="round"
          image="{{item.author.avatar}}">
          {{item.author.nickname ? item.author.nickname.charAt(0) : '行'}}
        </retro-avatar>
        <view class="post-author-info">
          <view class="post-author-name">{{item.author.nickname || item.author.wolfNo}}</view>
          <view class="post-author-no">ID: {{item.author.wolfNo || '--'}}</view>
        </view>
      </view>
      <view class="post-content">{{item.content}}</view>
    </view>
  </view>
</view>
