@import "../../styles/topbar.wxss";

/* Layout layer */
.community-page {
  min-height: 100vh;
  padding: 0;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.tab-strip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: 0 12rpx;
  padding: 10rpx 0 6rpx;
  border-bottom: 0;
}

.tab-list {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tab-item {
  height: 50rpx;
  padding: 0 16rpx;
  line-height: 50rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  font-size: 23rpx;
  color: var(--retro-muted-text);
}

.tab-item-active {
  border-color: var(--retro-accent-color);
  color: var(--retro-page-text);
  background: var(--retro-tab-active-bg);
}

.tab-tools {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tab-search {
  width: 250rpx;
  height: 50rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  display: flex;
  align-items: center;
}

.tab-search-input {
  flex: 1;
  min-width: 0;
  height: 50rpx;
  padding: 0 10rpx;
  font-size: 22rpx;
  color: var(--retro-page-text);
}

.tab-search-action {
  width: 52rpx;
  height: 50rpx;
  border-left: 1rpx solid var(--retro-panel-border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-tool {
  position: relative;
  height: 50rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-tool-notice {
  width: 62rpx;
}

.tab-tool-icon {
  width: 26rpx;
  height: 26rpx;
  opacity: 0.9;
}

.tab-tool-icon-search {
  width: 30rpx;
  height: 30rpx;
}

.tab-tool-badge {
  position: absolute;
  right: -8rpx;
  top: -12rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 2rpx;
  line-height: 1.15;
  font-size: 19rpx;
  color: var(--retro-accent-text);
  background: var(--retro-chip-bg);
}

.thread-list {
  display: flex;
  flex-direction: column;
  margin: 0 12rpx 20rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.thread-row {
  padding: 12rpx 14rpx;
  border-bottom: 1rpx solid var(--retro-row-border);
}

.thread-row:nth-child(even) {
  background: var(--retro-row-even-bg);
}

.thread-tag {
  font-size: 19rpx;
  color: var(--retro-accent-text);
}

.thread-title-line {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.thread-title {
  display: block;
  min-width: 0;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--retro-strong-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.thread-excerpt {
  margin-top: 6rpx;
  font-size: 21rpx;
  line-height: 1.48;
  color: var(--retro-muted-text);
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.thread-media-line {
  margin-top: 6rpx;
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.thread-media-line-single {
  align-items: flex-start;
}

.thread-excerpt-media {
  -webkit-line-clamp: 1;
}

.thread-excerpt-text {
  -webkit-line-clamp: 3;
}

.thread-media-cell {
  position: relative;
  width: 116rpx;
  height: 88rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-theme-item-bg);
  overflow: hidden;
}

.thread-media-video {
  width: 212rpx;
  height: 120rpx;
}

.thread-media-single-cell {
  width: 160rpx;
  height: 120rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-theme-item-bg);
  overflow: hidden;
}

.thread-media-single-image {
  width: 100%;
  height: 100%;
  display: block;
}

.thread-media-image {
  width: 100%;
  height: 100%;
}

.thread-media-video-mask {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(18, 23, 30, 0.28);
}

.thread-media-video-icon {
  width: 0;
  height: 0;
  margin-left: 4rpx;
  border-top: 11rpx solid transparent;
  border-bottom: 11rpx solid transparent;
  border-left: 16rpx solid var(--retro-strong-text);
}

.thread-media-more {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--retro-strong-text);
  background: rgba(14, 20, 28, 0.55);
}

.thread-meta-line {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  font-size: 20rpx;
  color: var(--retro-muted-text);
}

.thread-author-line {
  flex: 1;
  min-width: 0;
}

.thread-author {
  max-width: 208rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.thread-author-time {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: var(--retro-muted-text-2);
  white-space: nowrap;
}

.thread-stat {
  flex-shrink: 0;
  font-size: 20rpx;
  color: var(--retro-muted-text);
  white-space: nowrap;
}

.thread-row:last-child {
  border-bottom: none;
}

.thread-more-wrap {
  padding: 16rpx 0 20rpx;
  display: flex;
  justify-content: center;
}

.thread-more-text {
  font-size: 22rpx;
  color: var(--retro-muted-text);
}

