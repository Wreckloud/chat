/* Layout layer */
.community-page {
  min-height: 100vh;
  padding: 0;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.community-toolbar {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 22rpx;
  border-top: 1rpx solid var(--retro-toolbar-top-border);
  border-bottom: 1rpx solid var(--retro-toolbar-border);
  background: var(--retro-toolbar-bg);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.community-title {
  font-size: 31rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.community-total {
  margin-left: auto;
  font-size: 21rpx;
  color: var(--retro-muted-text-2);
}

.tab-strip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: 0;
  padding: 10rpx 12rpx;
  border-bottom: 1rpx solid var(--retro-tab-divider);
}

.tab-item {
  height: 50rpx;
  padding: 0 18rpx;
  line-height: 50rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  font-size: 23rpx;
  color: var(--retro-muted-text);
}

.tab-item-active {
  border-color: var(--retro-accent-color);
  color: var(--retro-page-text);
  background: rgba(255, 255, 255, 0.84);
}

.thread-board {
  display: flex;
  flex-direction: column;
  margin: 0 12rpx 20rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.thread-row {
  padding: 14rpx 16rpx 12rpx;
  border-bottom: 1rpx solid var(--retro-row-border);
}

.thread-row:nth-child(even) {
  background: var(--retro-row-even-bg);
}

.thread-title-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.thread-tag {
  font-size: 20rpx;
  color: var(--retro-muted-text);
}

.thread-tag-board {
  color: var(--retro-link-text);
}

.thread-tag-ann {
  color: #a24f2a;
}

.thread-tag-sticky {
  color: #235e94;
}

.thread-tag-essence {
  color: #5f5321;
}

.thread-tag-locked {
  color: #7a4258;
}

.thread-title {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  font-weight: 600;
  color: var(--retro-page-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.thread-meta-line {
  margin-top: 7rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.thread-author {
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.thread-stat {
  flex-shrink: 0;
}

.thread-time-line {
  margin-top: 4rpx;
}

.thread-time {
  font-size: 20rpx;
  color: var(--retro-muted-text-2);
}

.thread-row:last-child {
  border-bottom: none;
}

.thread-more-wrap {
  padding: 14rpx 0 18rpx;
  border-top: 1rpx solid var(--retro-row-border);
  display: flex;
  justify-content: center;
}

.thread-more-text {
  font-size: 22rpx;
  color: var(--retro-muted-text);
}
