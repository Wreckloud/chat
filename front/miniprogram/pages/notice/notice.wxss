.notice-page {
  min-height: 100vh;
  padding: 22rpx 18rpx 28rpx;
  box-sizing: border-box;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.retro-card {
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.notice-card {
  padding: 12rpx;
}

.notice-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4rpx 4rpx 10rpx;
  border-bottom: 1rpx solid var(--retro-row-border);
}

.notice-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 10rpx 4rpx 12rpx;
  border-bottom: 1rpx solid var(--retro-row-border);
}

.notice-filter-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 50rpx;
  padding: 0 18rpx;
  line-height: 1;
  font-size: 23rpx;
  color: var(--retro-muted-text);
  border: 1rpx solid var(--retro-row-border);
  background: rgba(255, 255, 255, 0.5);
  box-sizing: border-box;
}

.notice-filter-item-active {
  color: var(--retro-accent-text);
  border-color: var(--retro-accent-text);
  background: rgba(255, 255, 255, 0.78);
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--retro-strong-text);
}

.notice-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 50rpx;
  padding: 0 18rpx;
  line-height: 1;
  font-size: 23rpx;
  color: var(--retro-accent-text);
  border: 1rpx solid var(--retro-row-border);
  background: rgba(255, 255, 255, 0.55);
}

.notice-item {
  padding: 12rpx 6rpx;
  border-bottom: 1rpx solid var(--retro-row-border);
}

.notice-item-nav {
}

.notice-item-read {
  opacity: 0.72;
}

.notice-group {
  padding: 10rpx 0 2rpx;
}

.notice-group + .notice-group {
  border-top: 1rpx dashed var(--retro-row-border);
}

.notice-group-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4rpx 8rpx;
}

.notice-group-title {
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.notice-group-count {
  font-size: 20rpx;
  color: var(--retro-muted-text);
}

.notice-group-list {
  margin-left: 8rpx;
  padding-left: 12rpx;
  border-left: 2rpx solid var(--retro-row-border);
}

.notice-group-list .notice-item:last-child {
  border-bottom: 0;
}

.notice-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.notice-unread {
  flex-shrink: 0;
  min-width: 68rpx;
  text-align: left;
  color: var(--retro-accent-text);
  font-size: 21rpx;
  line-height: 1;
  animation: unread-blink 1.2s steps(1, end) infinite;
}

.notice-unread-hidden {
  visibility: hidden;
  animation: none;
}

.notice-content {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.4;
  color: var(--retro-body-text);
}

.notice-meta {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 20rpx;
  color: var(--retro-muted-text);
}

.notice-meta-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.notice-nav-hint {
  color: var(--retro-accent-text);
}

.empty-wrap {
  padding: 24rpx 0;
}

.loading-wrap {
  text-align: center;
  font-size: 22rpx;
  color: var(--retro-muted-text);
  padding: 20rpx 0 10rpx;
}

@keyframes unread-blink {
  0% {
    opacity: 1;
  }
  50% {
    opacity: 0.3;
  }
  100% {
    opacity: 1;
  }
}
