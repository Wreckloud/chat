<view class="notice-page {{themeClass}}">
  <view class="retro-card notice-card">
    <view class="notice-head">
      <view class="notice-title">系统通知</view>
      <view class="notice-action" bindtap="onMarkAllRead">[全部已读]</view>
    </view>

    <block wx:if="{{list.length > 0}}">
      <view
        wx:for="{{list}}"
        wx:key="noticeId"
        class="notice-item {{item.read ? 'notice-item-read' : ''}} {{item.navigable ? 'notice-item-nav' : ''}}"
        bindtap="onTapNotice"
        data-id="{{item.noticeId}}">
        <view class="notice-row">
          <text wx:if="{{!item.read}}" class="notice-unread">[未读]</text>
          <text class="notice-content">{{item.content}}</text>
        </view>
        <view class="notice-meta">
          <text>{{item.typeText}}</text>
          <view class="notice-meta-right">
            <text>{{item.timeText}}</text>
            <text wx:if="{{item.navigable}}" class="notice-nav-hint">[查看]</text>
          </view>
        </view>
      </view>
    </block>

    <view wx:elif="{{!loading}}" class="empty-wrap">
      <retro-empty title="暂无通知" description="系统提醒会显示在这里"></retro-empty>
    </view>

    <view wx:if="{{loading}}" class="loading-wrap">加载中...</view>
  </view>
</view>
