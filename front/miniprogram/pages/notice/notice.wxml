<view class="notice-page {{themeClass}}">
  <view class="retro-card notice-card">
    <view class="notice-head">
      <view class="notice-title">系统通知</view>
      <view class="notice-action" bindtap="onMarkAllRead">全部已读</view>
    </view>

    <view class="notice-filters">
      <view
        wx:for="{{filterOptions}}"
        wx:key="key"
        class="notice-filter-item {{activeFilterKey === item.key ? 'notice-filter-item-active' : ''}}"
        bindtap="onTapFilter"
        data-key="{{item.key}}">
        {{item.label}}
      </view>
    </view>

    <block wx:if="{{groupedList.length > 0}}">
      <view wx:for="{{groupedList}}" wx:key="groupKey" wx:for-item="group" class="notice-group">
        <view class="notice-group-head">
          <text class="notice-group-title">{{group.groupTitle}}</text>
          <text class="notice-group-count">{{group.items.length}}</text>
        </view>

        <view class="notice-group-list">
          <view
            wx:for="{{group.items}}"
            wx:key="noticeId"
            wx:for-item="notice"
            class="notice-item {{notice.read ? 'notice-item-read' : ''}} {{notice.navigable ? 'notice-item-nav' : ''}}"
            bindtap="onTapNotice"
            hover-class="none"
            data-id="{{notice.noticeId}}">
            <view class="notice-row">
              <text class="notice-unread {{notice.read ? 'notice-unread-hidden' : ''}}">[未读]</text>
              <text class="notice-content">{{notice.content}}</text>
            </view>
            <view class="notice-meta">
              <text>{{notice.typeText}}</text>
              <view class="notice-meta-right">
                <text>{{notice.timeText}}</text>
                <text wx:if="{{notice.navigable}}" class="notice-nav-hint">查看</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>

    <view wx:elif="{{!loading}}" class="empty-wrap">
      <retro-empty
        title="{{list.length === 0 ? '暂无通知' : '当前筛选为空'}}"
        description="{{list.length === 0 ? '系统提醒会显示在这里' : '可以切换筛选查看其他通知'}}"></retro-empty>
    </view>

    <view wx:if="{{loading}}" class="loading-wrap">加载中...</view>
  </view>
</view>
