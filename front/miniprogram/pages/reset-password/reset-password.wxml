<view class="container {{themeClass}}">
  <view class="header">
    <view class="title">{{copy.headerTitle}}</view>
    <view class="sub-title">{{copy.headerSubtitle}}</view>
  </view>

  <view class="form-card">
    <retro-input
      label="{{copy.fields.emailLabel}}"
      placeholder="{{copy.fields.emailPlaceholder}}"
      value="{{email}}"
      maxlength="{{128}}"
      bind:input="onEmailInput"
      class="form-input"
    />

    <retro-button
      theme="primary"
      size="large"
      block
      loading="{{sending}}"
      disabled="{{cooldown > 0}}"
      bindtap="handleSendLink"
      class="submit-btn">
      {{sendButtonText}}
    </retro-button>

    <view class="back-row">
      <text class="back-link" bindtap="goBackToLogin">{{copy.actions.backToLogin}}</text>
    </view>
  </view>
</view>
