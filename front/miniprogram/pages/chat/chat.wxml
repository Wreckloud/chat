<view class="chat-page {{themeClass}}">
  <view class="retro-toolbar">
    <view class="retro-title">WolfChat 会话面板</view>
    <view class="retro-count">总会话 {{conversationList.length}}</view>
  </view>

  <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" text="加载中..." />

  <t-empty
    wx:elif="{{conversationList.length === 0}}"
    icon="chat"
    description="还没有聊天记录">
    <t-button
      slot="actions"
      theme="primary"
      bindtap="goToMutual">
      去互关列表找行者
    </t-button>
  </t-empty>

  <view wx:else class="conversation-board">
    <view class="board-head">
      <text class="board-head-user">联系人</text>
      <text class="board-head-msg">最后消息</text>
      <text class="board-head-time">时间</text>
    </view>

    <t-swipe-cell
      wx:for="{{conversationList}}"
      wx:key="conversationId"
      wx:for-index="rowIndex"
      right="{{item.swipeActions}}"
      bind:click="onSwipeActionClick"
      data-id="{{item.conversationId}}">
      <view
        class="conversation-row {{rowIndex % 2 === 0 ? 'conversation-row-odd' : 'conversation-row-even'}} {{item.pinned ? 'conversation-row-pinned' : ''}}"
        bindtap="goChatDetail"
        data-id="{{item.conversationId}}">
        <view class="conversation-user" catchtap="goUserProfile" data-item="{{item}}">
          <t-avatar
            class="conversation-avatar"
            size="small"
            shape="round"
            image="{{item.targetAvatar}}">
            {{item.targetNickname ? item.targetNickname.charAt(0) : '行'}}
          </t-avatar>
          <view class="conversation-user-meta">
            <view class="conversation-user-line">
              <text class="conversation-name">{{item.targetNickname || item.targetWolfNo}}</text>
              <text wx:if="{{item.pinned}}" class="pin-flag">[置顶]</text>
            </view>
            <text class="conversation-no">ID: {{item.targetWolfNo || '--'}}</text>
          </view>
        </view>

        <view class="conversation-message">
          <text class="conversation-message-text">{{item.lastMessage || '暂无消息'}}</text>
        </view>

        <view class="conversation-time">
          <text class="conversation-time-text">{{item.formattedTime || '--'}}</text>
        </view>
      </view>
    </t-swipe-cell>
  </view>
</view>
