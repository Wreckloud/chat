<view class="chat-page {{themeClass}}">
  <view class="session-toolbar">
    <view class="session-title">会话列表</view>
    <view class="session-total">共 {{conversationList.length}}</view>
  </view>

  <retro-loading wx:if="{{loading}}" size="40rpx" text="加载中..." />

  <retro-empty
    wx:elif="{{conversationList.length === 0}}"
    icon="chat"
    description="还没有聊天记录">
    <retro-button
      slot="actions"
      theme="primary"
      bindtap="goToMutual">
      去互关列表找行者
    </retro-button>
  </retro-empty>

  <view wx:else class="session-board">
    <block wx:for="{{conversationSections}}" wx:key="key" wx:for-item="section" wx:for-index="sectionIndex">
      <view wx:if="{{sectionIndex > 0}}" class="session-divider"></view>

      <view class="session-group">
        <view class="session-group-head">
          <text class="session-group-title">{{section.title}}</text>
        </view>

        <view wx:if="{{section.showEmpty && section.list.length === 0}}" class="session-group-empty">{{section.emptyText}}</view>

        <retro-swipe-cell
          wx:for="{{section.list}}"
          wx:key="conversationId"
          right="{{item.swipeActions}}"
          bind:click="onSwipeActionClick"
          data-id="{{item.conversationId}}">
          <view
            class="session-row {{section.rowClass}} {{item.pinned ? 'session-row-pinned' : ''}}"
            bindtap="goChatDetail"
            data-id="{{item.conversationId}}">
            <view class="session-pin-bar {{item.pinned ? 'session-pin-bar-active' : ''}}"></view>
            <view class="session-user">
              <retro-avatar
                class="session-avatar {{item.isOnline ? '' : 'session-avatar-offline'}}"
                size="medium"
                shape="square"
                image="{{item.targetAvatar}}">
                {{item.targetNickname ? item.targetNickname.charAt(0) : '行'}}
              </retro-avatar>

              <view class="session-user-meta">
                <view class="session-name-line">
                  <text class="session-name">{{item.targetNickname || item.targetWolfNo || '未命名会话'}}</text>
                  <text wx:if="{{item.unreadCount > 0}}" class="session-unread">[{{item.unreadCount}}]</text>
                </view>
                <text class="session-presence {{item.isOnline ? 'session-presence-online' : ''}}">{{item.presenceText}}</text>
              </view>
            </view>

            <view class="session-preview-col">
              <text class="session-preview">{{item.lastMessage || '暂无消息'}}</text>
            </view>

            <text class="session-time">{{item.formattedTime || '--'}}</text>
          </view>
        </retro-swipe-cell>
      </view>
    </block>
  </view>
</view>
