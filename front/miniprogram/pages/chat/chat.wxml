<view class="chat-page {{themeClass}}">
  <view class="session-toolbar">
    <view class="session-title">会话列表</view>
    <view class="session-total">共 {{conversationList.length}}</view>
  </view>

  <retro-loading wx:if="{{loading}}" size="40rpx" text="加载中..." />

  <retro-empty
    wx:elif="{{conversationList.length === 0}}"
    icon="chat"
    description="还没有聊天记录">
    <retro-button
      slot="actions"
      theme="primary"
      bindtap="goToMutual">
      去互关列表找行者
    </retro-button>
  </retro-empty>

  <view wx:else class="session-board">
    <view class="session-group">
      <view class="session-group-head">
        <text class="session-group-title">在线好友 ({{onlineCount}})</text>
      </view>

      <view wx:if="{{onlineCount === 0}}" class="session-group-empty">暂无在线好友</view>

      <retro-swipe-cell
        wx:for="{{onlineConversations}}"
        wx:key="conversationId"
        right="{{item.swipeActions}}"
        bind:click="onSwipeActionClick"
        data-id="{{item.conversationId}}">
        <view
          class="session-row {{item.pinned ? 'session-row-pinned' : ''}}"
          bindtap="goChatDetail"
          data-id="{{item.conversationId}}">
          <retro-avatar
            class="session-avatar"
            size="medium"
            shape="square"
            image="{{item.targetAvatar}}">
            {{item.targetNickname ? item.targetNickname.charAt(0) : '行'}}
          </retro-avatar>

          <view class="session-meta">
            <view class="session-name-line">
              <text class="session-name">{{item.targetNickname || item.targetWolfNo || '未命名会话'}}</text>
              <text wx:if="{{item.pinned}}" class="session-pin">置顶</text>
            </view>
            <text class="session-presence session-presence-online">{{item.presenceText}}</text>
            <text class="session-preview">{{item.lastMessage || '暂无消息'}}</text>
          </view>

          <text class="session-time">{{item.formattedTime || '--'}}</text>
        </view>
      </retro-swipe-cell>
    </view>

    <view class="session-divider"></view>

    <view class="session-group">
      <view class="session-group-head">
        <text class="session-group-title">离线 ({{offlineCount}})</text>
      </view>

      <retro-swipe-cell
        wx:for="{{offlineConversations}}"
        wx:key="conversationId"
        right="{{item.swipeActions}}"
        bind:click="onSwipeActionClick"
        data-id="{{item.conversationId}}">
        <view
          class="session-row session-row-offline {{item.pinned ? 'session-row-pinned' : ''}}"
          bindtap="goChatDetail"
          data-id="{{item.conversationId}}">
          <retro-avatar
            class="session-avatar"
            size="medium"
            shape="square"
            image="{{item.targetAvatar}}">
            {{item.targetNickname ? item.targetNickname.charAt(0) : '行'}}
          </retro-avatar>

          <view class="session-meta">
            <view class="session-name-line">
              <text class="session-name">{{item.targetNickname || item.targetWolfNo || '未命名会话'}}</text>
              <text wx:if="{{item.pinned}}" class="session-pin">置顶</text>
            </view>
            <text class="session-presence">{{item.presenceText}}</text>
            <text class="session-preview">{{item.lastMessage || '暂无消息'}}</text>
          </view>

          <text class="session-time">{{item.formattedTime || '--'}}</text>
        </view>
      </retro-swipe-cell>
    </view>
  </view>
</view>
