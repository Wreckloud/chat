<view class="chat-container">
  <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" text="加载中..." />
  
  <t-empty 
    wx:elif="{{conversationList.length === 0}}" 
    icon="chat"
    description="还没有聊天记录">
    <t-button 
      slot="actions" 
      theme="primary" 
      bindtap="goToMutual">
      去互关列表找行者
    </t-button>
  </t-empty>
  
  <view wx:else>
    <t-cell-group wx:for="{{conversationList}}" wx:key="conversationId">
      <t-cell
        title="{{item.targetNickname || item.targetWolfNo}}"
        description="{{item.lastMessage || '暂无消息'}}"
        note="{{item.formattedTime || ''}}"
        arrow
        hover
        bindtap="goChatDetail"
        data-id="{{item.conversationId}}">
        <t-avatar
          slot="leftIcon"
          size="small"
          shape="round"
          image="{{item.targetAvatar}}">
          {{item.targetNickname ? item.targetNickname.charAt(0) : '行'}}
        </t-avatar>
      </t-cell>
    </t-cell-group>
  </view>
</view>