/* Layout layer */
.chat-page {
  min-height: 100vh;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.session-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 22rpx;
  border-top: 1rpx solid var(--retro-toolbar-top-border);
  border-bottom: 1rpx solid var(--retro-toolbar-border);
  background: var(--retro-toolbar-bg);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.lobby-entry {
  margin: 12rpx 12rpx 0;
  min-height: 86rpx;
  padding: 12rpx 14rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--retro-panel-border);
  border-top-color: var(--retro-board-head-top-border);
  border-bottom-color: var(--retro-board-head-bottom-border);
  background: var(--retro-board-head-bg);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.lobby-entry-main {
  min-width: 0;
  flex: 1;
}

.lobby-entry-title {
  display: block;
  font-size: 25rpx;
  font-weight: 600;
  color: var(--retro-board-head-text);
}

.lobby-entry-sub {
  display: block;
  margin-top: 4rpx;
  font-size: 21rpx;
  color: var(--retro-muted-text-2);
}

.lobby-entry-side {
  margin-left: 16rpx;
}

.lobby-entry-online {
  font-size: 23rpx;
  color: var(--retro-link-text);
  font-weight: 600;
}

.session-title {
  font-size: 27rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.session-total {
  font-size: 22rpx;
  color: var(--retro-muted-text-2);
}

.session-board {
  margin: 14rpx 12rpx 20rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.session-section-head {
  display: flex;
  align-items: center;
  padding: 12rpx 14rpx 10rpx;
  border-top: 1rpx solid var(--retro-board-head-top-border);
  border-bottom: 1rpx solid var(--retro-board-head-bottom-border);
  background: var(--retro-board-head-bg);
}

.session-section-title {
  font-size: 24rpx;
  color: var(--retro-board-head-text);
  font-weight: 600;
}

.session-section-empty {
  padding: 16rpx 14rpx;
  font-size: 22rpx;
  color: var(--retro-muted-text);
}

.session-divider {
  height: 1rpx;
  background: var(--retro-tab-divider);
}

.session-row {
  --session-pin-width: var(--retro-session-pin-width);
  --session-padding-x: var(--retro-session-row-padding-x);
  position: relative;
  display: flex;
  align-items: center;
  min-height: var(--retro-session-row-min-height);
  padding: 10rpx var(--session-padding-x) 10rpx calc(var(--session-padding-x) + var(--session-pin-width));
  border-bottom: 1rpx solid var(--retro-row-border);
  background: var(--retro-record-peer-bg);
  overflow: hidden;
}

.session-row-offline {
  background: var(--retro-row-even-bg);
}

.session-row-pinned {
  background: var(--retro-row-pinned-bg);
}

.session-pin-bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: var(--session-pin-width);
}

.session-pin-bar-active {
  background: var(--retro-accent-text);
}

.session-avatar {
  background: #ffffff;
  flex-shrink: 0;
}

.session-avatar-offline {
  filter: grayscale(100%);
  opacity: 0.72;
}

.session-user {
  width: var(--retro-session-user-width);
  min-width: 0;
  display: flex;
  align-items: flex-start;
}

.session-user-meta {
  min-width: 0;
  margin-left: 12rpx;
}

.session-name-line {
  display: flex;
  align-items: flex-start;
}

.session-title-badge {
  max-width: 132rpx;
  font-size: 19rpx;
}

.session-name {
  max-width: 200rpx;
  font-size: var(--retro-session-name-font-size);
  font-weight: 600;
  color: var(--retro-strong-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.session-unread {
  margin-left: 4rpx;
  align-self: flex-start;
  display: inline-block;
  flex: 0 0 auto;
  width: auto;
  min-width: 0;
  padding: 0;
  font-size: var(--retro-session-name-font-size);
  line-height: 1;
  color: var(--retro-accent-text);
  white-space: nowrap;
}

.session-presence {
  margin-top: 4rpx;
  font-size: var(--retro-session-presence-font-size);
  color: var(--retro-muted-text);
}

.session-presence-online {
  color: var(--retro-link-text);
}

.session-preview {
  display: block;
  font-size: var(--retro-session-preview-font-size);
  color: var(--retro-body-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.session-preview-col {
  flex: 1;
  min-width: 0;
  margin-left: var(--retro-session-inline-gap);
}

.session-time {
  margin-left: 12rpx;
  width: var(--retro-session-time-width);
  text-align: right;
  font-size: var(--retro-session-time-font-size);
  color: var(--retro-muted-text-2);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

