/* Layout layer */
.chat-page {
  min-height: 100vh;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.session-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 22rpx;
  border-top: 1rpx solid var(--retro-toolbar-top-border);
  border-bottom: 1rpx solid var(--retro-toolbar-border);
  background: var(--retro-toolbar-bg);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.session-title {
  font-size: 27rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.session-total {
  font-size: 22rpx;
  color: var(--retro-muted-text-2);
}

.session-board {
  margin: 14rpx 12rpx 20rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.session-group {
  width: 100%;
}

.session-group-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 14rpx 10rpx;
  border-top: 1rpx solid var(--retro-board-head-top-border);
  border-bottom: 1rpx solid var(--retro-board-head-bottom-border);
  background: var(--retro-board-head-bg);
}

.session-group-title {
  font-size: 24rpx;
  color: var(--retro-board-head-text);
  font-weight: 600;
}

.session-group-empty {
  padding: 16rpx 14rpx;
  font-size: 22rpx;
  color: var(--retro-muted-text);
}

.session-divider {
  height: 1rpx;
  background: var(--retro-tab-divider);
}

.session-row {
  display: flex;
  align-items: center;
  min-height: 124rpx;
  padding: 10rpx 14rpx;
  border-bottom: 1rpx solid var(--retro-row-border);
  background: var(--retro-record-peer-bg);
}

.session-row-offline {
  background: var(--retro-row-even-bg);
}

.session-row-pinned {
  background: var(--retro-row-pinned-bg);
}

.session-avatar {
  border: 1rpx solid var(--retro-avatar-border);
  background: #ffffff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  flex-shrink: 0;
}

.session-meta {
  flex: 1;
  min-width: 0;
  margin-left: 12rpx;
}

.session-name-line {
  display: flex;
  align-items: center;
  min-width: 0;
}

.session-name {
  max-width: 260rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--retro-strong-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.session-pin {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: var(--retro-accent-text);
}

.session-presence {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--retro-muted-text);
}

.session-presence-online {
  color: var(--retro-link-text);
}

.session-preview {
  margin-top: 4rpx;
  display: block;
  font-size: 21rpx;
  color: var(--retro-body-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.session-time {
  margin-left: 12rpx;
  width: 150rpx;
  text-align: right;
  font-size: 21rpx;
  color: var(--retro-muted-text-2);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
