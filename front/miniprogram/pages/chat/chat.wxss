/* Layout layer */
.chat-page {
  min-height: 100vh;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.retro-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 22rpx;
  border-top: 1rpx solid var(--retro-toolbar-top-border);
  border-bottom: 1rpx solid var(--retro-toolbar-border);
  background: var(--retro-toolbar-bg);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.retro-title {
  font-size: 27rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.retro-count {
  font-size: 22rpx;
  color: var(--retro-muted-text-2);
}

.conversation-board {
  margin: 14rpx 12rpx 20rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.board-head {
  display: flex;
  align-items: center;
  padding: 12rpx 14rpx;
  font-size: 22rpx;
  border-top: 1rpx solid var(--retro-board-head-top-border);
  border-bottom: 1rpx solid var(--retro-board-head-bottom-border);
  background: var(--retro-board-head-bg);
  color: var(--retro-board-head-text);
}

.board-head-user {
  width: 44%;
  padding-left: 6rpx;
}

.board-head-msg {
  width: 36%;
}

.board-head-time {
  width: 20%;
  text-align: right;
}

.conversation-row {
  display: flex;
  align-items: center;
  min-height: 112rpx;
  padding: 10rpx 14rpx;
  border-bottom: 1rpx solid var(--retro-row-border);
  background: var(--retro-record-peer-bg);
}

.conversation-row-even {
  background: var(--retro-row-even-bg);
}

.conversation-row-pinned {
  background: var(--retro-row-pinned-bg);
}

.conversation-user {
  width: 44%;
  display: flex;
  align-items: center;
}

.conversation-avatar {
  border: 1rpx solid var(--retro-avatar-border);
  background: #ffffff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.conversation-user-meta {
  min-width: 0;
  margin-left: 12rpx;
}

.conversation-user-line {
  display: flex;
  align-items: center;
  min-width: 0;
}

.conversation-name {
  max-width: 180rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--retro-strong-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.pin-flag {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: var(--retro-accent-text);
}

.conversation-no {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--retro-muted-text);
}

.conversation-message {
  width: 36%;
  min-width: 0;
  padding-right: 10rpx;
}

.conversation-message-text {
  font-size: 23rpx;
  color: var(--retro-body-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.conversation-time {
  width: 20%;
  display: flex;
  justify-content: flex-end;
}

.conversation-time-text {
  font-size: 22rpx;
  color: var(--retro-muted-text-2);
}
