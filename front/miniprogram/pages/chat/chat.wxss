@import "../../styles/topbar.wxss";

/* Layout layer */
.chat-page {
  min-height: 100vh;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
  --chat-side-gap: 12rpx;
  --retro-topbar-side-gap: var(--chat-side-gap);
}

.lobby-entry-wrap {
  margin: 12rpx var(--chat-side-gap) 0;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.tab-strip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: 0 var(--chat-side-gap);
  padding: 10rpx 0 6rpx;
  border-bottom: 0;
}

.tab-list {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tab-item {
  height: 50rpx;
  padding: 0 16rpx;
  line-height: 50rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  font-size: 23rpx;
  color: var(--retro-muted-text);
}

.tab-item-active {
  border-color: var(--retro-accent-color);
  color: var(--retro-page-text);
  background: var(--retro-tab-active-bg);
}

.tab-tools {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tab-search {
  width: 250rpx;
  height: 50rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  display: flex;
  align-items: center;
}

.tab-search-input {
  flex: 1;
  min-width: 0;
  height: 50rpx;
  padding: 0 10rpx;
  font-size: 22rpx;
  color: var(--retro-page-text);
}

.tab-search-placeholder {
  color: var(--retro-muted-text);
}

.tab-search-action {
  width: 52rpx;
  height: 50rpx;
  border-left: 1rpx solid var(--retro-panel-border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-tool {
  position: relative;
  height: 50rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-tool-notice {
  width: 62rpx;
}

.tab-tool-icon {
  width: 26rpx;
  height: 26rpx;
  opacity: 0.9;
}

.tab-tool-icon-search {
  width: 30rpx;
  height: 30rpx;
}

.tab-tool-badge {
  position: absolute;
  right: -8rpx;
  top: -12rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 2rpx;
  line-height: 1.15;
  font-size: 19rpx;
  color: var(--retro-accent-text);
  background: var(--retro-chip-bg);
}

.session-board {
  margin: 12rpx var(--chat-side-gap) 20rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.session-row {
  --session-pin-width: var(--retro-session-pin-width);
  --session-padding-x: var(--retro-session-row-padding-x);
  position: relative;
  display: flex;
  align-items: center;
  min-height: var(--retro-session-row-min-height);
  padding: 10rpx var(--session-padding-x) 10rpx calc(var(--session-padding-x) + var(--session-pin-width));
  border-bottom: 1rpx solid var(--retro-row-border);
  background: var(--retro-record-peer-bg);
  overflow: hidden;
}

.session-row-lobby {
  border-bottom: 0;
  min-height: 0;
  align-items: flex-start;
  padding-top: 12rpx;
  padding-bottom: 12rpx;
  padding-left: calc(var(--session-padding-x) + var(--session-pin-width));
  padding-right: var(--session-padding-x);
  background:
    repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.025) 0rpx,
      rgba(0, 0, 0, 0.025) 2rpx,
      rgba(0, 0, 0, 0) 2rpx,
      rgba(0, 0, 0, 0) 8rpx
    ),
    var(--retro-record-peer-bg);
}

.session-row-lobby .session-user {
  width: auto;
  flex: 1;
  justify-content: flex-start;
}

.lobby-main {
  width: 100%;
  min-width: 0;
}

.lobby-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.lobby-side {
  width: var(--retro-session-time-width);
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0;
}

.lobby-online-badge {
  font-size: 20rpx;
  line-height: 1.15;
  color: var(--retro-accent-text);
  white-space: nowrap;
}

.lobby-preview-line {
  margin-top: 8rpx;
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  min-width: 0;
  text-align: left;
}

.lobby-preview-text {
  flex: 1;
  min-width: 0;
}

.lobby-channel-tag {
  margin-left: 6rpx;
  margin-top: 1rpx;
  font-size: 20rpx;
  line-height: 1.15;
  color: var(--retro-accent-text);
}

.session-row-lobby .session-user-meta {
  margin-left: 0;
  text-align: left;
}

.session-row-lobby .session-name-line {
  justify-content: flex-start;
}

.session-row-offline {
  background: var(--retro-row-even-bg);
}

.session-row-pinned {
  background: var(--retro-row-pinned-bg);
}

.session-pin-bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: var(--session-pin-width);
}

.session-pin-bar-active {
  background: var(--retro-accent-text);
}

.session-avatar {
  display: block;
  line-height: 0;
  background: var(--retro-theme-item-bg);
  flex-shrink: 0;
}

.session-avatar-offline {
  filter: grayscale(100%);
  opacity: 0.72;
}

.session-user {
  width: var(--retro-session-user-width);
  min-width: 0;
  display: flex;
  align-items: flex-start;
}

.session-user-meta {
  min-width: 0;
  margin-left: 12rpx;
}

.session-name-line {
  display: flex;
  align-items: flex-start;
}

.session-title-badge {
  max-width: 132rpx;
  font-size: 19rpx;
}

.session-name {
  max-width: 200rpx;
  font-size: var(--retro-session-name-font-size);
  font-weight: 600;
  color: var(--retro-strong-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.session-unread {
  margin-left: 4rpx;
  margin-top: 1rpx;
  align-self: flex-start;
  display: inline-block;
  flex: 0 0 auto;
  width: auto;
  min-width: 0;
  padding: 0;
  font-size: var(--retro-session-unread-font-size);
  line-height: 1.15;
  color: var(--retro-accent-text);
  white-space: nowrap;
}

.session-presence {
  margin-top: 4rpx;
  font-size: var(--retro-session-presence-font-size);
  color: var(--retro-muted-text);
}

.session-presence-online {
  color: var(--retro-link-text);
}

.session-preview {
  display: block;
  font-size: var(--retro-session-preview-font-size);
  line-height: 1.15;
  color: var(--retro-body-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.session-preview-col {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  margin-left: var(--retro-session-inline-gap);
}

.session-time {
  margin-left: 12rpx;
  width: var(--retro-session-time-width);
  text-align: right;
  font-size: var(--retro-session-time-font-size);
  line-height: 1.15;
  color: var(--retro-muted-text-2);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

