<view class="container {{themeClass}}">
  <view class="header">
    <view class="title">修改密码</view>
    <view class="sub-title">修改后需要重新登录</view>
  </view>

  <view class="form-card">
    <retro-input
      label="原密码"
      placeholder="请输入当前密码"
      type="password"
      value="{{oldLoginKey}}"
      bind:input="onOldPasswordInput"
      bind:change="onOldPasswordInput"
      class="form-input"
    />

    <retro-input
      label="新密码"
      placeholder="请输入新密码（至少6位）"
      type="password"
      value="{{newLoginKey}}"
      bind:input="onNewPasswordInput"
      bind:change="onNewPasswordInput"
      class="form-input"
    />

    <view wx:if="{{newLoginKey}}" class="password-strength">
      <text class="strength-tag strength-{{passwordStrengthLevel}}">
        {{passwordStrengthLevel === 'strong' ? '强' : (passwordStrengthLevel === 'medium' ? '中' : '弱')}}
      </text>
      <text class="strength-text">{{passwordStrengthText}}</text>
    </view>

    <retro-input
      label="确认"
      placeholder="请再次输入新密码"
      type="password"
      value="{{confirmLoginKey}}"
      bind:input="onConfirmPasswordInput"
      bind:change="onConfirmPasswordInput"
      class="form-input"
    />

    <retro-button
      theme="primary"
      size="large"
      block
      loading="{{loading}}"
      bindtap="handleSubmit"
      class="submit-btn">
      确认修改
    </retro-button>
  </view>
</view>
