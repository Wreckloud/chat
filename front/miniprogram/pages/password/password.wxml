<view class="container {{themeClass}}">
  <view class="header">
    <view class="title">{{copy.headerTitle}}</view>
    <view class="sub-title">{{copy.headerSubtitle}}</view>
  </view>

  <view class="form-card">
    <view class="email-row">
      <text class="email-label">{{copy.fields.emailLabel}}</text>
      <text class="email-value">{{emailDisplay}}</text>
    </view>

    <retro-input
      label="{{copy.fields.oldLabel}}"
      placeholder="{{copy.fields.oldPlaceholder}}"
      type="password"
      value="{{oldLoginKey}}"
      hold-to-reveal="{{true}}"
      required="{{true}}"
      bind:input="onOldPasswordInput"
      class="form-input"
    />

    <retro-input
      label="{{copy.fields.newLabel}}"
      placeholder="{{copy.fields.newPlaceholder}}"
      type="password"
      value="{{newLoginKey}}"
      hold-to-reveal="{{true}}"
      meta-level="{{passwordStrengthLevel}}"
      meta-text="{{passwordStrengthInlineText}}"
      required="{{true}}"
      bind:input="onNewPasswordInput"
      class="form-input"
    />

    <retro-input
      label="{{copy.fields.confirmLabel}}"
      placeholder="{{copy.fields.confirmPlaceholder}}"
      type="password"
      value="{{confirmLoginKey}}"
      hold-to-reveal="{{true}}"
      required="{{true}}"
      bind:input="onConfirmPasswordInput"
      class="form-input"
    />

    <view class="code-row">
      <retro-input
        label="{{copy.fields.codeLabel}}"
        placeholder="{{copy.fields.codePlaceholder}}"
        value="{{emailCode}}"
        maxlength="{{6}}"
        type="number"
        bind:input="onEmailCodeInput"
        class="form-input code-input"
      />
      <retro-button
        theme="default"
        size="small"
        loading="{{codeSending}}"
        disabled="{{codeCooldown > 0 || !hasVerifiedEmail}}"
        bindtap="handleSendCode"
        class="code-btn">
        {{sendCodeButtonText}}
      </retro-button>
    </view>

    <retro-button
      theme="primary"
      size="large"
      block
      loading="{{loading}}"
      bindtap="handleSubmit"
      class="submit-btn">
      {{copy.submitButton}}
    </retro-button>
  </view>
</view>
