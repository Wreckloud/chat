.container {
  min-height: 100vh;
  padding: 30rpx 24rpx;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.header {
  text-align: center;
  padding: 16rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--retro-toolbar-border);
  background: var(--retro-toolbar-bg);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.sub-title {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--retro-muted-text);
}

.form-card {
  padding: 24rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.form-input {
  margin-bottom: 16rpx;
}

.email-row {
  min-height: 74rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-theme-item-bg);
}

.email-label {
  width: 98rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--retro-muted-text);
}

.email-value {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: var(--retro-page-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.code-row {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}

.code-input {
  flex: 1;
  min-width: 0;
  margin-bottom: 0;
}

.code-btn {
  flex-shrink: 0;
  width: 168rpx;
  margin-bottom: 16rpx;
}

.submit-btn {
  margin-top: 26rpx;
}
