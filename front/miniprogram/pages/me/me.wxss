.container {
  min-height: 100vh;
  padding: 30rpx;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.user-card {
  padding: 24rpx;
}

.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 16rpx;
}

.theme-card {
  padding: 24rpx;
}

.user-card,
.theme-card {
  background: var(--retro-panel-bg);
  border: 1rpx solid var(--retro-panel-border);
  border-radius: 8rpx;
  box-shadow: var(--retro-panel-shadow);
}

.theme-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.profile-list {
  border: 1rpx solid var(--retro-row-border, #c8d2e1);
  background: rgba(255, 255, 255, 0.32);
}

.profile-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 16rpx;
  border-bottom: 1rpx solid var(--retro-row-border, #c8d2e1);
}

.profile-row:last-child {
  border-bottom: none;
}

.profile-label {
  font-size: 23rpx;
  color: var(--retro-muted-text);
}

.profile-value {
  max-width: 420rpx;
  text-align: right;
  font-size: 23rpx;
  color: var(--retro-body-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.theme-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.theme-item {
  display: flex;
  align-items: center;
  padding: 14rpx 16rpx;
  border: 1rpx solid var(--retro-theme-item-border);
  background: var(--retro-theme-item-bg);
}

.theme-item-active {
  border-color: var(--retro-theme-item-active-border);
  background: var(--retro-theme-item-active-bg);
}

.theme-main {
  flex: 1;
  min-width: 0;
}

.theme-name {
  font-size: 25rpx;
  font-weight: 600;
}

.theme-desc {
  margin-top: 4rpx;
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.theme-preview {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin: 0 12rpx;
}

.theme-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 1rpx solid var(--retro-avatar-border);
}

.theme-state {
  width: 56rpx;
  text-align: right;
  font-size: 21rpx;
  color: var(--retro-accent-text);
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.loading-container {
  text-align: center;
  color: var(--retro-muted-text);
  padding: 40rpx 0;
}
