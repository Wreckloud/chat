.me-page {
  min-height: 100vh;
  padding: 22rpx 18rpx 28rpx;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
  box-sizing: border-box;
}

.me-main {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.retro-card {
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
  padding: 16rpx;
}

.identity-card {
  position: relative;
  padding: 18rpx;
}

.identity-main {
  display: flex;
  align-items: center;
  padding-right: 112rpx;
}

.identity-avatar {
  flex-shrink: 0;
  border: 1rpx solid var(--retro-avatar-border);
}

.identity-meta {
  min-width: 0;
  flex: 1;
  margin-left: 14rpx;
}

.identity-name-line {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 6rpx;
}

.identity-title-badge {
  flex-shrink: 0;
  max-width: 180rpx;
  padding: 0 8rpx;
  border: 1rpx solid var(--retro-row-border);
  background: rgba(255, 255, 255, 0.72);
  font-size: 20rpx;
  line-height: 1.2;
  color: var(--retro-accent-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.identity-name {
  min-width: 0;
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--retro-strong-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.identity-wolf {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--retro-muted-text);
}

.identity-email {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--retro-body-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.identity-edit-entry {
  position: absolute;
  top: 12rpx;
  right: 14rpx;
  font-size: 20rpx;
  color: var(--retro-accent-text);
}

.section-card {
  padding: 16rpx;
}

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--retro-strong-text);
}

.section-sub {
  font-size: 20rpx;
  color: var(--retro-muted-text);
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.quick-item {
  width: calc((100% - 10rpx) / 2);
  box-sizing: border-box;
  min-height: 104rpx;
  padding: 12rpx;
  border: 1rpx solid var(--retro-theme-item-border);
  background: var(--retro-theme-item-bg);
}

.quick-item:last-child:nth-child(odd) {
  width: 100%;
}

.quick-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--retro-body-text);
}

.quick-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.quick-badge {
  flex-shrink: 0;
  font-size: 20rpx;
  color: var(--retro-accent-text);
}

.quick-desc {
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 1.3;
  color: var(--retro-muted-text);
}

.theme-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.theme-item {
  position: relative;
  width: calc((100% - 8rpx) / 2);
  min-height: 82rpx;
  box-sizing: border-box;
  display: flex;
  align-items: stretch;
  gap: 8rpx;
  padding: 0;
  border: 1rpx solid var(--retro-theme-item-border);
  background: var(--retro-theme-item-bg);
  overflow: hidden;
}

.theme-item-active {
  border-color: var(--retro-theme-item-active-border);
  background: var(--retro-theme-item-active-bg);
}

.theme-main {
  flex: 1;
  min-width: 0;
  padding: 10rpx 56rpx 10rpx 10rpx;
}

.theme-name {
  font-size: 23rpx;
  font-weight: 600;
  color: var(--retro-strong-text);
}

.theme-desc {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--retro-muted-text);
  line-height: 1.25;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.theme-bars {
  width: 20rpx;
  height: auto;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
  margin: 0;
  align-self: stretch;
}

.theme-bar {
  flex: 1;
  min-height: 0;
  border-radius: 0;
}

.theme-selected {
  position: absolute;
  top: 8rpx;
  right: 10rpx;
  font-size: 20rpx;
  color: var(--retro-accent-text);
}

.danger-card {
  border-color: var(--retro-btn-danger-border);
}

.danger-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.account-divider {
  margin: 12rpx 0;
  border-top: 1rpx solid var(--retro-row-border);
}

.loading-container {
  text-align: center;
  color: var(--retro-muted-text);
  padding-top: 80rpx;
}
