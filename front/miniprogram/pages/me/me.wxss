.container {
  padding: 30rpx;
}

.user-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 16rpx;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.loading-container {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
}
