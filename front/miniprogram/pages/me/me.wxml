<view class="container">
  <view wx:if="{{userInfo}}" class="content">
    <view class="user-card">
      <view class="avatar-section">
        <t-avatar
          size="large"
          image="{{userInfo.avatar || ''}}"
          shape="round">
          {{userInfo.nickname ? userInfo.nickname.charAt(0) : '行'}}
        </t-avatar>
      </view>

      <t-cell-group class="info-group">
        <t-cell title="狼藉" note="{{userInfo.wolfNo}}" arrow="{{false}}" />
        <t-cell title="称谓" note="{{userInfo.nickname || userInfo.wolfNo}}" arrow="{{false}}" />
      </t-cell-group>
    </view>

    <view class="actions">
      <t-button theme="default" size="large" block bindtap="goFollow">
        关注列表
      </t-button>
      <t-button theme="danger" variant="outline" size="large" block bindtap="handleLogout">
        退出登录
      </t-button>
    </view>
  </view>

  <view wx:else class="loading-container">
    <view class="loading-text">加载中...</view>
  </view>
</view>
