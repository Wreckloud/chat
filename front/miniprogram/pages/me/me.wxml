<view class="me-page {{themeClass}}">
  <view wx:if="{{userInfo}}" class="me-main">
    <view class="retro-card identity-card">
      <view class="identity-edit-entry" catchtap="onTapProfileCard">[编辑资料]</view>
      <view class="identity-main" bindtap="onTapUserHome">
        <retro-avatar
          class="identity-avatar u-avatar-top"
          size="large"
          shape="square"
          image="{{userInfo.avatar || ''}}">
          {{userInfo.nickname ? userInfo.nickname.charAt(0) : '行'}}
        </retro-avatar>

        <view class="identity-meta">
          <view class="identity-name-line u-name-line">
            <view class="identity-name u-name">{{userInfo.nickname || userInfo.wolfNo}}</view>
            <view
              wx:if="{{userInfo.equippedTitleName}}"
              class="identity-title-badge u-title-badge retro-title-badge retro-title-badge-lg"
              style="{{userInfo.equippedTitleColor ? 'color:' + userInfo.equippedTitleColor + ';' : ''}}">
              [{{userInfo.equippedTitleName}}]
            </view>
          </view>
          <view class="identity-wolf">狼藉号 {{userInfo.wolfNo || '--'}}</view>
          <view class="identity-email">{{userInfo.email || '未绑定邮箱'}}</view>
        </view>
      </view>
    </view>

    <view class="retro-card section-card">
      <view class="section-head">
        <view class="section-title">常用功能</view>
        <view class="section-sub">个人高频入口</view>
      </view>

      <view class="quick-grid">
        <view
          wx:for="{{quickActions}}"
          wx:key="key"
          class="quick-item"
          bindtap="onTapQuickAction"
          data-key="{{item.key}}">
          <view class="quick-title-row">
            <text class="quick-title">{{item.title}}</text>
            <text
              wx:if="{{item.key === 'notice' && noticeUnreadCount > 0}}"
              class="quick-badge quick-badge-blink">
              [{{noticeUnreadCount}}]
            </text>
          </view>
          <view class="quick-desc">{{item.desc}}</view>
        </view>
      </view>
    </view>

    <view class="retro-card section-card">
      <view class="section-head">
        <view class="section-title">主题色</view>
        <view class="section-sub">界面风格切换</view>
      </view>

      <view class="theme-list">
        <view class="theme-row">
          <view
            wx:if="{{defaultThemeOption}}"
            class="theme-item {{themeName === defaultThemeOption.name ? 'theme-item-active' : ''}}"
            bindtap="onSelectTheme"
            data-theme="{{defaultThemeOption.name}}">
            <view wx:if="{{themeName === defaultThemeOption.name}}" class="theme-selected">[已选]</view>
            <view class="theme-bars">
              <view
                wx:for="{{defaultThemeOption.preview}}"
                wx:key="*this"
                wx:for-item="color"
                class="theme-bar"
                style="background-color: {{color}};"></view>
            </view>
            <view class="theme-main">
              <view class="theme-name">{{defaultThemeOption.label}}</view>
              <view class="theme-desc">{{defaultThemeOption.description}}</view>
            </view>
          </view>

          <view
            class="theme-item theme-item-dark {{darkModeEnabled ? 'theme-item-active' : ''}}"
            bindtap="onToggleDarkMode">
            <view class="theme-selected {{darkModeEnabled ? '' : 'theme-selected-muted'}}">
              {{darkModeEnabled ? '[已开]' : '[关闭]'}}
            </view>
            <view class="theme-bars theme-bars-dark">
              <view class="theme-bar theme-bar-dark-1"></view>
              <view class="theme-bar theme-bar-dark-2"></view>
              <view class="theme-bar theme-bar-dark-3"></view>
            </view>
            <view class="theme-main">
              <view class="theme-name">夜行模式</view>
              <view class="theme-desc">整站随主题一起变暗</view>
            </view>
          </view>
        </view>

        <view class="theme-row">
          <view class="theme-item theme-item-placeholder">
            <view class="theme-bars theme-bars-placeholder">
              <view class="theme-bar theme-bar-placeholder-1"></view>
              <view class="theme-bar theme-bar-placeholder-2"></view>
              <view class="theme-bar theme-bar-placeholder-3"></view>
            </view>
            <view class="theme-main">
              <view class="theme-name">施工中</view>
              <view class="theme-desc">尽请期待 comming soon.</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="retro-card section-card danger-card">
      <view class="section-head">
        <view class="section-title">账号操作</view>
        <view class="section-sub">账号与安全</view>
      </view>

      <view class="quick-grid">
        <view
          wx:for="{{accountActions}}"
          wx:key="key"
          class="quick-item"
          bindtap="onTapAccountAction"
          data-key="{{item.key}}">
          <view class="quick-title">{{item.title}}</view>
          <view class="quick-desc">{{item.desc}}</view>
        </view>
      </view>

      <view class="account-divider"></view>

      <view class="danger-actions">
        <retro-button theme="default" variant="outline" size="large" block bindtap="handleLogout">
          退出登录
        </retro-button>
        <retro-button theme="danger" variant="outline" size="large" block bindtap="handleDeactivateAccount">
          注销账号（测试）
        </retro-button>
      </view>
    </view>
  </view>

  <view wx:else class="loading-container">
    <view>加载中...</view>
  </view>
</view>
