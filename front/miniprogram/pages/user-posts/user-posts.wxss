.user-posts-page {
  min-height: 100vh;
  padding: 12rpx;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
  box-sizing: border-box;
}

.thread-list {
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.thread-item {
  padding: 12rpx 14rpx;
  border-bottom: 1rpx solid var(--retro-row-border);
}

.thread-item:nth-child(even) {
  background: var(--retro-row-even-bg);
}

.thread-item:last-child {
  border-bottom: none;
}

.thread-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10rpx;
}

.thread-title-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.thread-tag {
  flex-shrink: 0;
  font-size: 20rpx;
  color: var(--retro-accent-text);
}

.thread-title {
  flex: 1;
  min-width: 0;
  font-size: 25rpx;
  color: var(--retro-body-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.thread-sticky-action {
  flex-shrink: 0;
  font-size: 20rpx;
  color: var(--retro-link-text);
}

.thread-excerpt {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: var(--retro-body-text);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.thread-media-line {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.thread-media-cell {
  position: relative;
  width: 128rpx;
  height: 96rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-theme-item-bg);
  overflow: hidden;
}

.thread-media-video {
  width: 162rpx;
}

.thread-media-image {
  width: 100%;
  height: 100%;
}

.thread-media-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--retro-muted-text);
  background: var(--retro-theme-item-bg);
}

.thread-media-video-mask {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(18, 23, 30, 0.28);
}

.thread-media-video-icon {
  width: 0;
  height: 0;
  margin-left: 4rpx;
  border-top: 11rpx solid transparent;
  border-bottom: 11rpx solid transparent;
  border-left: 16rpx solid var(--retro-strong-text);
}

.thread-media-more {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--retro-strong-text);
  background: rgba(14, 20, 28, 0.55);
}

.thread-meta-row,
.thread-time-row {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--retro-muted-text);
}

.more-row {
  padding: 14rpx 0 8rpx;
  display: flex;
  justify-content: center;
}

.more-text {
  font-size: 21rpx;
  color: var(--retro-muted-text);
}
