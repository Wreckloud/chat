<view class="user-posts-page {{themeClass}}">
  <view class="user-posts-toolbar retro-topbar">
    <view class="retro-topbar-title">{{isSelf ? '我的帖子' : (nickname + ' 的帖子')}}</view>
    <view class="retro-topbar-meta">共 {{total}}</view>
  </view>

  <view wx:if="{{isSelf}}" class="tab-strip">
    <view class="tab-list">
      <view
        wx:for="{{tabs}}"
        wx:key="value"
        class="tab-item {{item.value === activeTab ? 'tab-item-active' : ''}}"
        data-tab="{{item.value}}"
        bindtap="onSelectTab">
        {{item.label}}
      </view>
    </view>
    <view class="tab-search">
      <input
        class="tab-search-input"
        placeholder="搜索帖子"
        maxlength="40"
        value="{{searchKeyword}}"
        confirm-type="search"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm" />
      <view class="tab-search-action" bindtap="onSearchTap">
        <image class="tab-tool-icon tab-tool-icon-search" src="/images/icon-search.svg" mode="aspectFit" />
      </view>
    </view>
  </view>

  <retro-empty
    wx:if="{{!loading && threads.length === 0}}"
    description="{{isSelf && activeTab === 'draft' ? '暂无草稿' : (isSelf && activeTab === 'trash' ? '垃圾站为空' : '暂无帖子')}}" />

  <view wx:elif="{{threads.length > 0}}" class="thread-list">
    <view
      wx:for="{{threads}}"
      wx:key="threadId"
      class="thread-item"
      bindtap="onTapThread"
      data-thread-id="{{item.threadId}}">
      <view class="thread-title-row">
        <view class="thread-title-main">
          <text wx:if="{{isSelf && activeTab === 'draft'}}" class="thread-tag">[草稿]</text>
          <text wx:if="{{isSelf && activeTab === 'trash'}}" class="thread-tag">[已删除]</text>
          <text wx:if="{{item.threadType === 'STICKY'}}" class="thread-tag">[置顶]</text>
          <text wx:if="{{item.isEssence}}" class="thread-tag">[精华]</text>
          <text class="thread-title">{{item.title}}</text>
        </view>

        <view wx:if="{{isSelf && activeTab === 'mine'}}" class="thread-row-actions">
          <view
            class="thread-action-link"
            catchtap="onEditThread"
            data-thread-id="{{item.threadId}}">
            [编辑]
          </view>
          <view
            class="thread-action-link"
            catchtap="onToggleSticky"
            data-thread-id="{{item.threadId}}"
            data-sticky="{{item.threadType === 'STICKY'}}">
            {{item.threadType === 'STICKY' ? '[取消置顶]' : '[置顶到主页]'}}
          </view>
          <view
            class="thread-action-link thread-action-danger"
            catchtap="onDeleteThread"
            data-thread-id="{{item.threadId}}">
            [删除]
          </view>
        </view>

        <view wx:if="{{isSelf && activeTab === 'draft'}}" class="thread-row-actions">
          <view class="thread-action-link">[继续编辑]</view>
        </view>

        <view wx:if="{{isSelf && activeTab === 'trash'}}" class="thread-row-actions">
          <view
            class="thread-action-link thread-action-danger"
            catchtap="onPurgeThread"
            data-thread-id="{{item.threadId}}">
            [彻底删除]
          </view>
        </view>
      </view>

      <view wx:if="{{item.contentPreview}}" class="thread-excerpt">{{item.contentPreview}}</view>

      <view wx:if="{{item.videoPosterUrl || (item.previewImageUrls && item.previewImageUrls.length > 0)}}" class="thread-media-line">
        <view wx:if="{{item.videoPosterUrl}}" class="thread-media-cell thread-media-video">
          <image class="thread-media-image" src="{{item.videoPosterUrl}}" mode="aspectFill" />
          <view class="thread-media-video-mask">
            <view class="thread-media-video-icon"></view>
          </view>
        </view>
        <view
          wx:for="{{item.previewImageUrls}}"
          wx:key="*this"
          wx:for-item="previewUrl"
          wx:for-index="previewIndex"
          class="thread-media-cell">
          <image class="thread-media-image" src="{{previewUrl}}" mode="aspectFill" />
          <view
            wx:if="{{item.hasMoreImages && previewIndex === item.previewImageUrls.length - 1}}"
            class="thread-media-more">
            +{{item.imageUrls.length - item.previewImageUrls.length}}
          </view>
        </view>
      </view>

      <view class="thread-meta-row">
        <text>回 {{item.replyCount}} / 看 {{item.viewCount}} / 赞 {{item.likeCount}}</text>
      </view>
      <view class="thread-time-row">
        <text>{{item.timePrefix}} {{item.timeRelativeText || item.timeText || '--'}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{threads.length > 0}}" class="more-row">
    <text wx:if="{{loadingMore}}" class="more-text">加载中...</text>
    <text wx:elif="{{!hasMore}}" class="more-text">没有更多帖子</text>
  </view>
</view>
