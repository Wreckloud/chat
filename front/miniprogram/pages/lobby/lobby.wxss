@import "../../styles/im-chat-common.wxss";
@import "../../styles/topbar.wxss";

.im-page {
  --im-message-list-top: 88rpx;
}

.lobby-panel {
  position: relative;
  z-index: 10;
  justify-content: space-between;
}

.lobby-panel-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 3rpx;
}

.lobby-online {
  margin-left: 12rpx;
  flex-shrink: 0;
  font-size: 23rpx;
  color: var(--retro-link-text);
  font-weight: 600;
}

.lobby-active {
  display: block;
  margin-top: 0;
  max-width: 100%;
  font-size: 21rpx;
  font-weight: 600;
  color: var(--retro-muted-text-2);
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.lobby-recent {
  display: block;
  margin-top: 0;
  max-width: 100%;
  font-size: 21rpx;
  font-weight: 500;
  color: var(--retro-muted-text);
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
