@import "../../styles/im-chat-common.wxss";

.im-page {
  --im-message-list-top: 126rpx;
}

.lobby-panel {
  position: relative;
  z-index: 10;
  padding: 10rpx 14rpx 12rpx;
  border-top: 1rpx solid var(--retro-toolbar-top-border);
  border-bottom: 1rpx solid var(--retro-toolbar-border);
  background: var(--retro-toolbar-bg);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.lobby-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.lobby-title {
  font-size: 29rpx;
  font-weight: 600;
  color: var(--retro-strong-text);
}

.lobby-online {
  font-size: 23rpx;
  color: var(--retro-link-text);
  font-weight: 600;
}

.lobby-active {
  display: block;
  margin-top: 4rpx;
  font-size: 21rpx;
  color: var(--retro-muted-text-2);
}

.lobby-recent {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--retro-muted-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
