<view class="post-detail-page {{themeClass}}">
  <retro-loading wx:if="{{loading && !thread}}" size="40rpx" text="加载中..." />
  <retro-empty wx:elif="{{!loading && !thread}}" description="主题不存在或已删除" />

  <view wx:else class="post-detail-main">
    <scroll-view
      class="post-detail-scroll"
      style="bottom: {{replyListBottomPx}}px;"
      scroll-y
      scroll-into-view="{{replyScrollIntoView}}"
      lower-threshold="80"
      bindscrolltolower="onReachBottom"
      enable-back-to-top>
      <view class="thread-card">
        <view class="thread-title-line">
          <text wx:if="{{thread.threadType === 'ANNOUNCEMENT'}}" class="thread-tag thread-tag-ann">[公告]</text>
          <text wx:if="{{thread.status === 'LOCKED'}}" class="thread-tag thread-tag-locked">[锁]</text>
          <text class="thread-title">{{thread.title}}</text>
        </view>

        <view class="thread-header">
          <view
            class="thread-author-main"
            data-user-id="{{thread.author.userId}}"
            bindtap="onTapUserElement">
            <retro-avatar
              class="author-avatar u-avatar-top"
              size="small"
              shape="square"
              image="{{thread.author.avatar}}">
              {{thread.author.nickname ? thread.author.nickname.charAt(0) : '行'}}
            </retro-avatar>
            <view class="thread-info">
              <view class="thread-name-line u-name-line">
                <view class="thread-name u-name">{{thread.author.displayName || thread.author.nickname || thread.author.wolfNo}}</view>
                <view
                  wx:if="{{thread.author.displayTitleName}}"
                  class="user-title-badge u-title-badge retro-title-badge retro-title-badge-sm"
                  style="{{thread.author.displayTitleColor ? 'color:' + thread.author.displayTitleColor + ';' : ''}}">
                  [{{thread.author.displayTitleName}}]
                </view>
              </view>
              <view class="thread-meta-line">
                <text class="thread-time">{{thread.timePrefix}} {{thread.timeText || '--'}}</text>
                <text class="thread-info-sep">/</text>
                <text class="thread-stat">赞 {{thread.likeCount || 0}} / 回 {{thread.replyCount}} / 阅 {{thread.viewCount}}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="thread-content">{{content}}</view>

        <view wx:if="{{thread.imageUrls && thread.imageUrls.length > 0}}" class="thread-media-grid">
          <image
            wx:for="{{thread.imageUrls}}"
            wx:key="*this"
            class="thread-media-image"
            src="{{item}}"
            mode="aspectFill"
            data-url="{{item}}"
            bindtap="previewThreadImage" />
        </view>

        <view
          wx:if="{{thread.videoUrl}}"
          class="thread-video-card"
          data-url="{{thread.videoUrl}}"
          bindtap="previewThreadVideo">
          <image
            wx:if="{{thread.videoPosterUrl}}"
            class="thread-video-poster"
            src="{{thread.videoPosterUrl}}"
            mode="aspectFill"
            lazy-load="{{true}}" />
          <view class="thread-video-play-mask">
            <view class="thread-video-play-icon"></view>
          </view>
        </view>

        <view class="thread-action-line">
          <view class="thread-primary-actions">
            <view class="thread-like-btn" bindtap="handleToggleThreadLike">
              <text class="thread-like-label {{thread.likedByCurrentUser ? 'thread-like-label-liked' : ''}}">{{thread.likedByCurrentUser ? '已赞' : '点赞'}}</text>
            </view>
            <text wx:if="{{canManageThread}}" class="manage-btn" bindtap="goEditThread">编辑</text>
          </view>
          <view wx:if="{{canManageThread}}" class="thread-danger-actions">
            <text class="manage-btn danger" bindtap="handleDeleteThread">删帖</text>
          </view>
        </view>
      </view>

      <view>
        <view class="section-title-line">
          <view class="section-title">楼层回复</view>
          <view class="reply-sort-switch" bindtap="onSwitchReplySort">{{replySortText}}</view>
        </view>
        <retro-empty wx:if="{{replies.length === 0}}" description="暂无回复" />

        <block wx:for="{{replyRows}}" wx:key="replyId" wx:for-item="item">
          <view class="reply-item {{item.depth > 0 ? 'reply-item-nested' : ''}}" style="{{item.depth > 0 ? 'margin-left:' + item.indentRpx + 'rpx;' : ''}}">
            <view class="reply-header">
              <view
                class="reply-author-main"
                data-user-id="{{item.author.userId}}"
                bindtap="onTapUserElement">
                <retro-avatar
                  class="reply-avatar u-avatar-top"
                  size="small"
                  shape="square"
                  image="{{item.author.avatar}}">
                  {{item.author.nickname ? item.author.nickname.charAt(0) : '行'}}
                </retro-avatar>
                <view class="reply-info">
                  <view class="reply-author-line u-name-line">
                    <view class="reply-author u-name">{{item.author.displayName || item.author.nickname || item.author.wolfNo}}</view>
                    <view
                      wx:if="{{item.author.displayTitleName}}"
                      class="user-title-badge u-title-badge retro-title-badge retro-title-badge-sm"
                      style="{{item.author.displayTitleColor ? 'color:' + item.author.displayTitleColor + ';' : ''}}">
                      [{{item.author.displayTitleName}}]
                    </view>
                  </view>
                  <view class="reply-time">{{item.timeText}}</view>
                </view>
              </view>
              <view class="reply-floor">#{{item.floorNo}}</view>
            </view>

            <view class="reply-content">{{item.content}}</view>
            <image
              wx:if="{{item.imageUrl}}"
              class="reply-image"
              src="{{item.imageUrl}}"
              mode="widthFix"
              data-url="{{item.imageUrl}}"
              bindtap="previewReplyImage" />

            <view class="reply-actions">
              <view class="reply-primary-actions">
                <view class="reply-action-btn reply-like-btn {{item.likedByCurrentUser ? 'reply-like-btn-liked' : ''}}" bindtap="handleToggleReplyLike" data-id="{{item.replyId}}">
                  <text class="reply-action-text">{{item.likedByCurrentUser ? '已赞' : '点赞'}}</text>
                  <text class="reply-action-count">{{item.likeCount || 0}}</text>
                </view>
                <view class="reply-action-btn quote-btn" bindtap="chooseReplyTarget" data-reply-id="{{item.replyId}}">
                  <text class="reply-action-text">回复</text>
                </view>
              </view>
              <view wx:if="{{item.canDelete}}" class="reply-danger-actions">
                <view class="reply-action-btn reply-delete-btn" bindtap="handleDeleteReply" data-id="{{item.replyId}}">
                  <text class="reply-action-text">删除</text>
                </view>
              </view>
            </view>
          </view>
        </block>

        <view wx:if="{{replies.length > 0}}" class="reply-more-wrap">
          <retro-button
            wx:if="{{replyHasMore && !replyLoading}}"
            size="small"
            theme="default"
            bind:tap="loadMoreReplies">
            加载更多
          </retro-button>
          <text wx:elif="{{replyLoading}}" class="reply-more-text">加载中...</text>
          <text wx:else class="reply-more-text">没有更多回复</text>
        </view>
      </view>
      <view id="reply-bottom-anchor" class="reply-bottom-anchor"></view>
    </scroll-view>

    <view id="reply-dock" class="reply-dock" style="bottom: {{keyboardHeightPx}}px;">
      <view wx:if="{{replyTargetHint}}" class="quote-hint">
        <text class="quote-hint-text">{{replyTargetHint}}</text>
        <text class="quote-hint-close" bindtap="clearReplyTarget">x</text>
      </view>

      <view class="reply-input">
        <view class="reply-emoji-trigger" bindtap="toggleReplyEmojiPanel">
          <image class="reply-emoji-icon" src="/images/icon-kaomoji.svg" mode="aspectFit" />
        </view>
        <view class="reply-field-wrap">
          <input
            class="reply-field"
            placeholder="写下回复..."
            value="{{replyContent}}"
            focus="{{replyFocused}}"
            maxlength="2000"
            adjust-position="{{false}}"
            hold-keyboard="{{true}}"
            confirm-hold="{{true}}"
            bindkeyboardheightchange="onReplyKeyboardHeightChange"
            bindfocus="onReplyFocus"
            bindblur="onReplyBlur"
            bindinput="onReplyInput"
            confirm-type="send"
            bindconfirm="handleReply"
          />
        </view>
        <view class="reply-action-bar">
          <retro-button
            class="reply-compose-btn"
            theme="default"
            size="medium"
            disabled="{{replySubmitting}}"
            bind:tap="chooseReplyImage">
            图片
          </retro-button>
          <retro-button
            class="reply-compose-btn"
            theme="primary"
            size="medium"
            disabled="{{replySubmitting || !canReplySubmit}}"
            bind:tap="onReplySubmitTap">
            {{replySubmitting ? '提交中' : '回帖'}}
          </retro-button>
        </view>
      </view>

      <view wx:if="{{replyEmojiPanelVisible}}" class="reply-emoji-panel">
        <scroll-view class="reply-emoji-scroll" scroll-y enhanced="{{true}}" show-scrollbar="{{false}}">
          <view class="reply-emoji-grid">
            <view
              wx:for="{{replyEmojiList}}"
              wx:key="*this"
              class="reply-emoji-item"
              data-emoji="{{item}}"
              bindtap="onSelectReplyEmoji">
              <text class="reply-emoji-item-text">{{item}}</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <view wx:if="{{replyImage}}" class="reply-media-box">
        <image
          class="reply-media-image"
          src="{{replyImage.path}}"
          mode="aspectFill"
          data-url="{{replyImage.path}}"
          bindtap="previewReplyImage" />
        <view class="reply-media-remove" bindtap="clearReplyImage">×</view>
      </view>
    </view>
  </view>
</view>
