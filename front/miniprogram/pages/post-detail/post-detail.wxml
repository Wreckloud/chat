<view class="post-detail-page {{themeClass}}">
  <retro-loading wx:if="{{loading && !post}}" size="40rpx" text="加载中..." />
  <retro-empty wx:elif="{{!loading && !post}}" description="帖子不存在或已删除" />

  <view wx:else>
    <view class="post-card">
      <view class="post-header">
        <retro-avatar 
          class="author-avatar"
          size="medium"
          image="{{post.author.avatar}}"
          shape="round"
          catchtap="goUserProfile"
          data-user="{{post.author}}">
          {{post.author.nickname ? post.author.nickname.charAt(0) : '行'}}
        </retro-avatar>
        <view class="post-info" catchtap="goUserProfile" data-user="{{post.author}}">
          <view class="post-name">{{post.author.nickname || post.author.wolfNo}}</view>
          <view class="post-time">{{post.timeText}}</view>
        </view>
        <retro-button size="small" theme="primary" bindtap="handleFollowAuthor">关注</retro-button>
      </view>
      <view class="post-content">{{post.content}}</view>
    </view>

    <view>
      <view class="section-title">评论</view>
      <retro-empty wx:if="{{comments.length === 0}}" description="暂无评论" />

      <view wx:for="{{comments}}" wx:key="commentId" class="comment-item">
        <view class="comment-header">
          <retro-avatar 
            class="comment-avatar"
            size="small"
            image="{{item.author.avatar}}"
            shape="round"
            catchtap="goUserProfile"
            data-user="{{item.author}}">
            {{item.author.nickname ? item.author.nickname.charAt(0) : '行'}}
          </retro-avatar>
          <view class="comment-info" catchtap="goUserProfile" data-user="{{item.author}}">
            <view class="comment-name">{{item.author.nickname || item.author.wolfNo}}</view>
            <view class="comment-time">{{item.timeText}}</view>
          </view>
        </view>
        <view class="comment-content">{{item.content}}</view>
      </view>
    </view>

    <view class="comment-input">
      <retro-input
        class="comment-field"
        placeholder="写下评论..."
        value="{{commentContent}}"
        maxlength="300"
        bind:input="onCommentInput"
      />
      <retro-button theme="primary" size="small" bindtap="handleComment">发送</retro-button>
    </view>
  </view>
</view>
