/* Layout layer */
.post-detail-page {
  min-height: 100vh;
  padding: 22rpx 18rpx;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.post-card,
.comment-item,
.comment-input {
  padding: 18rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.post-card {
  margin-bottom: 16rpx;
}

.post-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.author-avatar,
.comment-avatar {
  border: 1rpx solid var(--retro-avatar-border);
}

.post-info {
  flex: 1;
}

.post-name {
  font-size: 28rpx;
  font-weight: 600;
}

.post-time {
  margin-top: 2rpx;
  font-size: 22rpx;
  color: var(--retro-muted-text);
}

.post-content {
  font-size: 26rpx;
  line-height: 1.55;
  color: var(--retro-body-text);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin: 8rpx 0 14rpx;
}

.comment-item {
  margin-bottom: 12rpx;
}

.comment-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.comment-info {
  flex: 1;
}

.comment-name {
  font-size: 25rpx;
  font-weight: 600;
}

.comment-time {
  margin-top: 2rpx;
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.comment-content {
  margin-top: 10rpx;
  padding-left: 58rpx;
  font-size: 25rpx;
  line-height: 1.5;
  color: var(--retro-body-text);
}

.comment-input {
  margin-top: 16rpx;
}
