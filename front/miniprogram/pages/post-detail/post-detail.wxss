/* Layout layer */
.post-detail-page {
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.thread-card,
.reply-item {
  padding: 18rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.post-detail-main {
  flex: 1;
  min-height: 0;
  position: relative;
}

.post-detail-scroll {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 88px;
  min-height: 0;
  padding: 22rpx 18rpx 0;
  box-sizing: border-box;
}

.thread-card {
  margin-bottom: 16rpx;
}

.thread-title-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.thread-tag {
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.thread-tag-ann {
  color: var(--retro-accent-color);
}

.thread-tag-locked {
  color: var(--retro-muted-text);
}

.thread-title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.thread-header {
  margin-bottom: 12rpx;
}

.thread-author-main {
  min-width: 0;
  display: flex;
  align-items: flex-start;
}

.thread-info {
  min-width: 0;
  margin-left: 10rpx;
  flex: 1;
}

.thread-name {
  font-size: 26rpx;
  font-weight: 600;
  white-space: nowrap;
}

.thread-time {
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.thread-stat {
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.thread-meta-line {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 2rpx;
}

.thread-info-sep {
  font-size: 20rpx;
  color: var(--retro-muted-text);
}

.thread-action-line {
  margin-top: 12rpx;
  padding-top: 10rpx;
  border-top: 1rpx dashed var(--retro-panel-border);
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 12rpx;
}

.thread-primary-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.thread-danger-actions {
  margin-left: auto;
  display: flex;
  align-items: center;
}

.thread-like-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 21rpx;
  line-height: 1;
  color: var(--retro-accent-color);
}

.thread-like-label {
  display: inline-flex;
  align-items: center;
  line-height: 1;
}

.thread-like-label-liked {
  color: var(--retro-accent-text);
}

.manage-btn {
  font-size: 21rpx;
  color: var(--retro-accent-color);
}

.manage-btn.danger {
  color: var(--retro-btn-danger-border);
}

.thread-content {
  font-size: 26rpx;
  line-height: 1.55;
  color: var(--retro-body-text);
}

.thread-media-grid {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.thread-media-image {
  width: 100%;
  height: 194rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-theme-item-bg);
  box-shadow: var(--retro-panel-shadow);
}

.thread-video-card {
  position: relative;
  margin-top: 12rpx;
  height: 360rpx;
  overflow: hidden;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.thread-video-poster {
  width: 100%;
  height: 100%;
  display: block;
}

.thread-video-play-mask {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.28), rgba(0, 0, 0, 0.06));
}

.thread-video-play-icon {
  width: 0;
  height: 0;
  border-top: 16rpx solid transparent;
  border-bottom: 16rpx solid transparent;
  border-left: 24rpx solid var(--retro-strong-text);
  filter: drop-shadow(0 0 6rpx rgba(0, 0, 0, 0.35));
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin: 8rpx 0 14rpx;
}

.section-title-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.reply-sort-switch {
  font-size: 23rpx;
  color: var(--retro-accent-color);
  margin-bottom: 10rpx;
}

.reply-item {
  margin-bottom: 12rpx;
}

.reply-item-nested {
  background: var(--retro-thread-reply-bg, rgba(211, 224, 218, 0.86));
}

.reply-item:last-child {
  margin-bottom: 0;
}

.reply-more-wrap {
  padding: 6rpx 0 14rpx;
  display: flex;
  justify-content: center;
}

.reply-more-text {
  font-size: 22rpx;
  color: var(--retro-muted-text);
}

.reply-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.reply-author-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: flex-start;
}

.reply-avatar {
  flex-shrink: 0;
}

.reply-info {
  min-width: 0;
  margin-left: 10rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.reply-floor {
  flex-shrink: 0;
  font-size: 23rpx;
  color: var(--retro-muted-text);
  text-align: right;
}

.reply-author {
  white-space: nowrap;
  font-size: 24rpx;
  font-weight: 600;
}

.reply-time {
  margin-top: 2rpx;
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.reply-content {
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.5;
  color: var(--retro-body-text);
}

.reply-image {
  margin-top: 8rpx;
  display: block;
  width: 360rpx;
  max-width: 100%;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-theme-item-bg);
  box-shadow: var(--retro-panel-shadow);
}

.reply-actions {
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx dashed var(--retro-panel-border);
  display: flex;
  justify-content: flex-start;
  align-items: center;
  gap: 12rpx;
}

.reply-primary-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.reply-danger-actions {
  margin-left: auto;
  display: flex;
  align-items: center;
}

.reply-action-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  line-height: 1;
  font-size: 21rpx;
  color: var(--retro-accent-color);
}

.reply-action-text,
.reply-action-count {
  display: inline-flex;
  align-items: center;
  line-height: 1;
}

.reply-action-count {
  color: var(--retro-muted-text);
}

.reply-like-btn-liked {
  color: var(--retro-accent-text);
}

.reply-delete-btn {
  color: var(--retro-btn-danger-border);
}

.quote-hint {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-bottom: 10rpx;
  padding: 10rpx 14rpx;
  border: 1rpx solid var(--retro-theme-item-active-border);
  background: var(--retro-theme-item-active-bg);
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.quote-hint-text {
  flex: 1;
  min-width: 0;
  line-height: 1.4;
}

.quote-hint-close {
  flex-shrink: 0;
  width: 30rpx;
  height: 30rpx;
  line-height: 28rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--retro-accent-color);
}

.reply-dock {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 10rpx 18rpx calc(10rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--retro-composer-border);
  background: var(--retro-composer-bg);
  box-shadow: var(--retro-toolbar-shadow, inset 0 1rpx 0 rgba(255, 255, 255, 0.7));
}

.reply-input {
  --reply-compose-height: var(--retro-chat-composer-input-height, 64rpx);
  --reply-compose-btn-min-width: var(--retro-chat-composer-btn-min-width, 96rpx);
  --reply-compose-icon-size: 30rpx;
  display: flex;
  align-items: center;
  gap: var(--retro-chat-row-gap, 10rpx);
}

.reply-emoji-trigger {
  width: var(--reply-compose-height);
  height: var(--reply-compose-height);
  flex-shrink: 0;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-theme-item-bg);
  box-shadow: var(--retro-input-inner-shadow, inset 0 1rpx 0 rgba(255, 255, 255, 0.82));
  display: flex;
  align-items: center;
  justify-content: center;
}

.reply-emoji-icon {
  width: var(--reply-compose-icon-size);
  height: var(--reply-compose-icon-size);
}

.reply-field-wrap {
  flex: 1;
  min-width: 0;
}

.reply-field {
  width: 100%;
  height: var(--reply-compose-height);
  box-sizing: border-box;
  padding: 0 18rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-theme-item-bg);
  font-size: 24rpx;
  color: var(--retro-page-text);
  box-shadow: var(--retro-input-inner-shadow, inset 0 1rpx 0 rgba(255, 255, 255, 0.82));
}

.reply-action-bar {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  gap: var(--retro-chat-row-gap, 10rpx);
}

.reply-compose-btn {
  min-width: var(--reply-compose-btn-min-width);
}

.reply-compose-btn .retro-btn {
  min-height: var(--reply-compose-height);
}

.reply-emoji-panel {
  margin-top: 10rpx;
  padding: 0;
  border: 0;
  background: var(--retro-composer-bg);
  box-shadow: none;
  overflow: hidden;
}

.reply-emoji-scroll {
  height: 376rpx;
  box-sizing: border-box;
  padding: 0;
  overflow: hidden;
}

.reply-emoji-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8rpx;
  align-content: start;
}

.reply-emoji-item {
  height: 56rpx;
  padding: 8rpx 10rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-page-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.reply-emoji-item-text {
  max-width: 100%;
  font-size: 20rpx;
  line-height: 1.2;
  color: var(--retro-strong-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.reply-media-box {
  margin-top: 10rpx;
  width: 182rpx;
  position: relative;
}

.reply-media-image {
  display: block;
  width: 182rpx;
  height: 182rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-theme-item-bg);
  box-shadow: var(--retro-panel-shadow);
}

.reply-media-remove {
  position: absolute;
  right: 0;
  top: 0;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--retro-strong-text);
  background: rgba(0, 0, 0, 0.56);
}

.reply-bottom-anchor {
  height: 1rpx;
}
