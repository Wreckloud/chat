/* Layout layer */
.post-detail-page {
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.thread-card,
.reply-item {
  padding: 18rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.post-detail-main {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.post-detail-scroll {
  flex: 1;
  min-height: 0;
  padding: 22rpx 18rpx 0;
  box-sizing: border-box;
}

.thread-card {
  margin-bottom: 16rpx;
}

.thread-title-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.thread-tag {
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.thread-tag-ann {
  color: #a24f2a;
}

.thread-tag-sticky {
  color: #235e94;
}

.thread-tag-essence {
  color: #5f5321;
}

.thread-tag-locked {
  color: #7a4258;
}

.thread-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.thread-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.author-avatar {
  border: 1rpx solid var(--retro-avatar-border);
}

.thread-info {
  flex: 1;
}

.thread-name {
  font-size: 28rpx;
  font-weight: 600;
}

.thread-time {
  margin-top: 2rpx;
  font-size: 22rpx;
  color: var(--retro-muted-text);
}

.thread-stat {
  font-size: 22rpx;
  color: var(--retro-muted-text);
}

.thread-stat-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.thread-manage-actions {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 12rpx;
}

.manage-btn {
  font-size: 21rpx;
  color: var(--retro-accent-color);
}

.manage-btn.danger {
  color: #b4474f;
}

.thread-content {
  font-size: 26rpx;
  line-height: 1.55;
  color: var(--retro-body-text);
}

.thread-last-line {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
  gap: 10rpx;
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin: 8rpx 0 14rpx;
}

.reply-item {
  margin-bottom: 12rpx;
}

.reply-item:last-child {
  margin-bottom: 0;
}

.reply-more-wrap {
  padding: 6rpx 0 14rpx;
  display: flex;
  justify-content: center;
}

.reply-more-text {
  font-size: 22rpx;
  color: var(--retro-muted-text);
}

.reply-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.reply-floor {
  width: 70rpx;
  font-size: 23rpx;
  color: var(--retro-muted-text);
}

.reply-author {
  flex: 1;
  font-size: 24rpx;
  font-weight: 600;
}

.reply-time {
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.reply-quote {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.reply-quote-content {
  margin-top: 2rpx;
  font-size: 20rpx;
  color: var(--retro-muted-text);
}

.reply-content {
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.5;
  color: var(--retro-body-text);
}

.reply-actions {
  margin-top: 8rpx;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
}

.quote-btn {
  font-size: 21rpx;
  color: var(--retro-accent-color);
}

.reply-delete-btn {
  font-size: 21rpx;
  color: #b4474f;
}

.quote-hint {
  margin-bottom: 10rpx;
  padding: 10rpx 14rpx;
  border: 1rpx dashed var(--retro-panel-border);
  background: rgba(255, 255, 255, 0.75);
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.reply-dock {
  padding: 10rpx 18rpx calc(10rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--retro-composer-border);
  background: var(--retro-composer-bg);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
}

.reply-input {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.reply-field {
  flex: 1;
}
