/* Layout layer */
.post-detail-page {
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.thread-card,
.reply-item {
  padding: 18rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.post-detail-main {
  flex: 1;
  min-height: 0;
  position: relative;
}

.post-detail-scroll {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 88px;
  min-height: 0;
  padding: 22rpx 18rpx 0;
  box-sizing: border-box;
}

.thread-card {
  margin-bottom: 16rpx;
}

.thread-title-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.thread-tag {
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.thread-tag-ann {
  color: #a24f2a;
}

.thread-tag-sticky {
  color: #235e94;
}

.thread-tag-essence {
  color: #5f5321;
}

.thread-tag-locked {
  color: #7a4258;
}

.thread-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.thread-header {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.thread-author-main {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
}

.author-avatar {
  border: 1rpx solid var(--retro-avatar-border);
}

.thread-info {
  min-width: 0;
  margin-left: 12rpx;
  flex: 1;
}

.thread-name {
  min-width: 0;
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.thread-name-line {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.thread-time {
  margin-top: 2rpx;
  font-size: 22rpx;
  color: var(--retro-muted-text);
}

.thread-stat {
  font-size: 22rpx;
  color: var(--retro-muted-text);
}

.thread-stat-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.thread-like-btn {
  font-size: 21rpx;
  color: var(--retro-accent-color);
}

.thread-manage-actions {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 12rpx;
}

.manage-btn {
  font-size: 21rpx;
  color: var(--retro-accent-color);
}

.manage-btn.danger {
  color: #b4474f;
}

.thread-content {
  font-size: 26rpx;
  line-height: 1.55;
  color: var(--retro-body-text);
}

.thread-media-grid {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.thread-media-image {
  width: 100%;
  height: 194rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: #ffffff;
  box-shadow: var(--retro-panel-shadow);
}

.thread-video-card {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.thread-video-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--retro-page-text);
}

.thread-video-sub {
  margin-top: 4rpx;
  display: block;
  font-size: 20rpx;
  color: var(--retro-muted-text);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin: 8rpx 0 14rpx;
}

.reply-item {
  margin-bottom: 12rpx;
}

.reply-item:last-child {
  margin-bottom: 0;
}

.reply-more-wrap {
  padding: 6rpx 0 14rpx;
  display: flex;
  justify-content: center;
}

.reply-more-text {
  font-size: 22rpx;
  color: var(--retro-muted-text);
}

.reply-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.reply-author-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
}

.reply-avatar {
  flex-shrink: 0;
  border: 1rpx solid var(--retro-avatar-border);
}

.reply-info {
  min-width: 0;
  margin-left: 10rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.reply-floor {
  flex-shrink: 0;
  font-size: 23rpx;
  color: var(--retro-muted-text);
  text-align: right;
}

.reply-author {
  min-width: 0;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 24rpx;
  font-weight: 600;
}

.reply-author-line {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.reply-time {
  margin-top: 2rpx;
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.reply-quote {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.user-title-badge {
  flex-shrink: 0;
  max-width: 130rpx;
  margin-left: 6rpx;
  font-size: 18rpx;
  line-height: 1.2;
  color: var(--retro-accent-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.reply-quote-content {
  margin-top: 2rpx;
  font-size: 20rpx;
  color: var(--retro-muted-text);
}

.reply-content {
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.5;
  color: var(--retro-body-text);
}

.reply-image {
  margin-top: 8rpx;
  display: block;
  width: 360rpx;
  max-width: 100%;
  border: 1rpx solid var(--retro-panel-border);
  background: #ffffff;
  box-shadow: var(--retro-panel-shadow);
}

.reply-actions {
  margin-top: 8rpx;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
}

.quote-btn {
  font-size: 21rpx;
  color: var(--retro-accent-color);
}

.reply-like-btn {
  font-size: 21rpx;
  color: var(--retro-accent-color);
}

.reply-delete-btn {
  font-size: 21rpx;
  color: #b4474f;
}

.quote-hint {
  margin-bottom: 10rpx;
  padding: 10rpx 14rpx;
  border: 1rpx dashed var(--retro-panel-border);
  background: rgba(255, 255, 255, 0.75);
  font-size: 21rpx;
  color: var(--retro-muted-text);
}

.reply-dock {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 10rpx 18rpx calc(10rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--retro-composer-border);
  background: var(--retro-composer-bg);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
}

.reply-input {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.reply-field {
  flex: 1;
  height: 64rpx;
  box-sizing: border-box;
  padding: 0 16rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: #ffffff;
  font-size: 24rpx;
  color: var(--retro-page-text);
}

.reply-action-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.reply-media-box {
  margin-top: 10rpx;
  width: 182rpx;
  position: relative;
}

.reply-media-image {
  display: block;
  width: 182rpx;
  height: 182rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: #ffffff;
  box-shadow: var(--retro-panel-shadow);
}

.reply-media-remove {
  position: absolute;
  right: 0;
  top: 0;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 24rpx;
  color: #ffffff;
  background: rgba(0, 0, 0, 0.56);
}

.reply-bottom-anchor {
  height: 1rpx;
}
