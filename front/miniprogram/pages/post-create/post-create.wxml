<view class="post-create-page {{themeClass}}">
  <view class="editor-toolbar">
    <view class="title">发布帖子</view>
    <view class="hint">最多 500 字</view>
  </view>

  <view class="editor-card">
    <retro-textarea
      placeholder="说点什么..."
      value="{{content}}"
      maxlength="500"
      bind:input="onContentInput"
    />

    <retro-button
      class="submit-btn"
      theme="primary"
      size="large"
      block
      loading="{{loading}}"
      bindtap="handleSubmit">
      发布
    </retro-button>
  </view>
</view>
