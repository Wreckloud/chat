@import "../../styles/topbar.wxss";

/* Layout layer */
.post-create-page {
  min-height: 100vh;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
  --retro-topbar-side-gap: 12rpx;
}

.editor-toolbar {
  margin-bottom: 0;
}

.editor-body {
  padding: 12rpx;
}

.editor-card {
  padding: 18rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.field-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.field-row.column {
  justify-content: space-between;
}

.field-label {
  width: 80rpx;
  font-size: 24rpx;
  color: var(--retro-muted-text);
}

.title-input {
  flex: 1;
}

.content-hint {
  font-size: 20rpx;
  color: var(--retro-muted-text);
}

.content-toolbar {
  display: flex;
  align-items: center;
  margin: -4rpx 0 10rpx;
}

.content-emoji-trigger {
  width: 64rpx;
  height: 64rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-theme-item-bg);
  box-shadow: var(--retro-input-inner-shadow, inset 0 1rpx 0 rgba(255, 255, 255, 0.82));
  display: flex;
  align-items: center;
  justify-content: center;
}

.content-emoji-icon {
  width: 36rpx;
  height: 36rpx;
}

.content-emoji-panel {
  margin-top: 10rpx;
  margin-bottom: 14rpx;
  padding: 0;
  border: 0;
  background: var(--retro-composer-bg);
  box-shadow: none;
  overflow: hidden;
}

.content-emoji-scroll {
  height: 376rpx;
  box-sizing: border-box;
  padding: 0;
  overflow: hidden;
}

.content-emoji-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8rpx;
  align-content: start;
}

.content-emoji-item {
  height: 56rpx;
  padding: 8rpx 10rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-page-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.content-emoji-item-text {
  max-width: 100%;
  font-size: 20rpx;
  line-height: 1.2;
  color: var(--retro-strong-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.media-head-row {
  margin-top: 4rpx;
}

.media-toolbar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.media-image-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.media-image-item {
  position: relative;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-theme-item-bg);
  box-shadow: var(--retro-panel-shadow);
}

.media-image {
  display: block;
  width: 100%;
  height: 196rpx;
}

.media-remove {
  position: absolute;
  right: 0;
  top: 0;
  width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--retro-strong-text);
  background: rgba(0, 0, 0, 0.58);
}

.media-video-card {
  position: relative;
  margin-bottom: 14rpx;
  height: 360rpx;
  overflow: hidden;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.media-video-poster {
  width: 100%;
  height: 100%;
  display: block;
}

.media-video-poster-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--retro-muted-text);
  background: var(--retro-theme-item-bg, rgba(255, 255, 255, 0.86));
}

.media-video-play-mask {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.28), rgba(0, 0, 0, 0.06));
}

.media-video-play-icon {
  width: 0;
  height: 0;
  border-top: 16rpx solid transparent;
  border-bottom: 16rpx solid transparent;
  border-left: 24rpx solid var(--retro-strong-text);
  filter: drop-shadow(0 0 6rpx rgba(0, 0, 0, 0.35));
}

.submit-btn {
  margin-top: 18rpx;
}

.theme-dark .post-create-page .field-label,
.theme-dark .post-create-page .content-hint {
  color: var(--retro-body-text);
}
