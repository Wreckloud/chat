.container {
  padding: 30rpx;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.profile-info {
  flex: 1;
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.wolfno {
  font-size: 26rpx;
  color: #999;
}

.actions {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}
