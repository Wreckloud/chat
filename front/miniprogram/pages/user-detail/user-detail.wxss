/* Layout layer */
.user-detail-page {
  min-height: 100vh;
  padding: 22rpx 18rpx;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.profile-info {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
}

.wolfno {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: var(--retro-muted-text);
}

.actions {
  margin-top: 16rpx;
  display: flex;
  gap: 12rpx;
}

.hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--retro-muted-text);
}
