<view class="user-detail-page {{themeClass}}">
  <retro-loading wx:if="{{loading && !userInfo}}" size="40rpx" text="加载中..." />

  <view wx:elif="{{userInfo}}" class="user-detail-main">
    <view class="profile-card">
      <view class="profile-main">
        <retro-avatar
          class="u-avatar-top"
          size="large"
          shape="square"
          image="{{userInfo.avatar}}">
          {{userInfo.nickname ? userInfo.nickname.charAt(0) : '行'}}
        </retro-avatar>

        <view class="profile-info">
          <view class="nickname-line u-name-line">
            <view class="nickname u-name">{{userInfo.displayName || userInfo.nickname || userInfo.wolfNo}}</view>
            <view
              wx:if="{{userInfo.displayTitleName}}"
              class="profile-title-badge u-title-badge retro-title-badge retro-title-badge-lg"
              style="{{userInfo.displayTitleColor ? 'color:' + userInfo.displayTitleColor + ';' : ''}}">
              [{{userInfo.displayTitleName}}]
            </view>
          </view>
          <view class="wolfno">狼藉号 {{userInfo.wolfNo || '--'}}</view>
          <view wx:if="{{userInfo.signature}}" class="signature">{{userInfo.signature}}</view>
          <view wx:if="{{userInfo.bio}}" class="bio">{{userInfo.bio}}</view>
        </view>
      </view>

      <view wx:if="{{!isSelf && !isTargetDisabled}}" class="profile-actions">
        <retro-button
          size="small"
          theme="{{isFollowing ? 'default' : 'primary'}}"
          loading="{{followLoading}}"
          disabled="{{followLoading}}"
          bindtap="toggleFollow">
          {{isFollowing ? '取消关注' : '关注'}}
        </retro-button>
        <retro-button
          size="small"
          theme="primary"
          disabled="{{chatLoading}}"
          loading="{{chatLoading}}"
          bindtap="goChat">
          私聊
        </retro-button>
      </view>
      <view wx:if="{{!isSelf && isTargetDisabled}}" class="mutual-hint">该用户已注销，当前展示为历史资料</view>
      <view wx:if="{{!isSelf && !isMutual && !isTargetDisabled}}" class="mutual-hint">未互关时单向最多发送 3 条消息，收到对方回复后解除限制</view>
    </view>

    <view class="core-stats-card">
      <view class="core-stat">
        <view class="core-value">{{activeDayCountText}}</view>
        <view class="core-label">活跃天数</view>
      </view>
      <view class="core-stat">
        <view class="core-value">{{totalLikeCountText}}</view>
        <view class="core-label">总获赞</view>
      </view>
      <view class="core-stat">
        <view class="core-value">{{followerCountText}}</view>
        <view class="core-label">粉丝数</view>
      </view>
    </view>

    <view class="showcase-card">
      <view class="section-head">
        <view class="section-title">头衔橱窗</view>
        <view class="section-sub">最多展示 3 个</view>
      </view>
      <view wx:if="{{showcaseTitles.length === 0}}" class="showcase-empty">暂无头衔</view>
      <view wx:else class="showcase-list">
        <view wx:for="{{showcaseTitles}}" wx:key="achievementCode" class="showcase-item">
          <text
            class="showcase-title"
            style="{{item.titleColor ? 'color:' + item.titleColor + ';' : ''}}">
            [{{item.titleName}}]
          </text>
        </view>
      </view>
    </view>

    <view class="meta-card">
      <view class="meta-row">
        <text class="meta-label">关注</text>
        <text class="meta-value">{{followingCountText}}</text>
      </view>
      <view class="meta-row">
        <text class="meta-label">发帖</text>
        <text class="meta-value">{{threadCountText}}</text>
      </view>
      <view class="meta-row">
        <text class="meta-label">回帖</text>
        <text class="meta-value">{{replyCountText}}</text>
      </view>
      <view class="meta-row">
        <text class="meta-label">最近活跃</text>
        <text class="meta-value">{{lastActiveText}}</text>
      </view>
    </view>

    <view class="latest-card">
      <view class="section-head">
        <view class="section-title">最近帖子</view>
        <view class="section-link" bindtap="goAllThreads">{{isSelf ? '[管理置顶]' : '[查看全部]'}}</view>
      </view>

      <retro-empty wx:if="{{latestThreads.length === 0}}" description="暂无帖子" />
      <view
        wx:for="{{latestThreads}}"
        wx:key="threadId"
        class="thread-item"
        bindtap="onTapThread"
        data-thread-id="{{item.threadId}}">
        <view class="thread-title-row">
          <text wx:if="{{item.threadType === 'STICKY'}}" class="thread-tag">[置顶]</text>
          <text wx:if="{{item.isEssence}}" class="thread-tag">[精华]</text>
          <text class="thread-title">{{item.title}}</text>
        </view>
        <view wx:if="{{item.contentPreview}}" class="thread-excerpt">{{item.contentPreview}}</view>
        <view wx:if="{{item.videoPosterUrl || (item.previewImageUrls && item.previewImageUrls.length > 0)}}" class="thread-media-line">
          <view wx:if="{{item.videoPosterUrl}}" class="thread-media-cell thread-media-video">
            <image class="thread-media-image" src="{{item.videoPosterUrl}}" mode="aspectFill" />
            <view class="thread-media-video-mask">
              <view class="thread-media-video-icon"></view>
            </view>
          </view>
          <view
            wx:for="{{item.previewImageUrls}}"
            wx:key="*this"
            wx:for-item="previewUrl"
            wx:for-index="previewIndex"
            class="thread-media-cell">
            <image class="thread-media-image" src="{{previewUrl}}" mode="aspectFill" />
            <view
              wx:if="{{item.hasMoreImages && previewIndex === item.previewImageUrls.length - 1}}"
              class="thread-media-more">
              +{{item.imageUrls.length - item.previewImageUrls.length}}
            </view>
          </view>
        </view>
        <view class="thread-meta-row">
          <text>回 {{item.replyCount}} / 看 {{item.viewCount}} / 赞 {{item.likeCount}}</text>
        </view>
        <view class="thread-time-row">
          <text>{{item.timePrefix}} {{item.timeText || '--'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
