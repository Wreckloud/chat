<view class="user-detail-page {{themeClass}}">
  <t-loading wx:if="{{loading}}" theme="circular" size="40rpx" text="加载中..." />

  <view>
    <view wx:if="{{userInfo}}" class="profile-card">
      <t-avatar
        size="large"
        shape="round"
        image="{{userInfo.avatar}}">
        {{userInfo.nickname ? userInfo.nickname.charAt(0) : '行'}}
      </t-avatar>
      <view class="profile-info">
        <view class="nickname">{{userInfo.nickname || userInfo.wolfNo}}</view>
        <view class="wolfno">狼藉号：{{userInfo.wolfNo || '-'}}</view>
      </view>
    </view>

    <view wx:if="{{userInfo && !isSelf}}" class="actions">
      <retro-button
        size="small"
        theme="{{isFollowing ? 'default' : 'primary'}}"
        loading="{{followLoading}}"
        disabled="{{followLoading}}"
        bindtap="toggleFollow">
        {{isFollowing ? '取消关注' : '关注'}}
      </retro-button>
      <retro-button
        size="small"
        theme="primary"
        disabled="{{chatLoading}}"
        loading="{{chatLoading}}"
        bindtap="goChat">
        私聊
      </retro-button>
    </view>

    <view wx:if="{{userInfo && !isSelf && !isMutual}}" class="hint">
      互相关注后才能聊天
    </view>
  </view>
</view>
