.container {
  min-height: 100vh;
  padding: 30rpx 24rpx;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.header {
  text-align: center;
  padding: 16rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--retro-toolbar-border);
  background: var(--retro-toolbar-bg);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.sub-title {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--retro-muted-text);
}

.status-card,
.form-card {
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
}

.status-card {
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.status-label {
  font-size: 24rpx;
  color: var(--retro-muted-text);
}

.status-tag {
  padding: 4rpx 12rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-theme-item-bg);
  font-size: 20rpx;
  color: var(--retro-body-text);
}

.status-tag-unbound {
  border-color: var(--retro-panel-border);
  color: var(--retro-muted-text);
}

.status-tag-pending {
  border-color: var(--retro-accent-color);
  color: var(--retro-accent-text);
}

.status-tag-verified {
  border-color: var(--retro-btn-primary-border);
  color: var(--retro-btn-primary-outline-text);
}

.status-email {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--retro-strong-text);
  word-break: break-all;
}

.status-hint {
  margin-top: 8rpx;
  font-size: 21rpx;
  line-height: 1.5;
  color: var(--retro-muted-text);
}

.form-card {
  padding: 24rpx;
}

.email-input {
  margin-bottom: 18rpx;
}
