<template name="imChatBody">
  <scroll-view
    id="message-list"
    class="im-message-list"
    style="bottom: {{messageListBottomPx}}px;"
    scroll-y
    scroll-into-view="{{scrollIntoView}}"
    upper-threshold="80"
    bindscrolltoupper="onMessageListUpper"
    bindtap="onTapMessageList"
    enable-back-to-top>
    <view wx:if="{{loading && messages.length === 0}}" class="im-state-text">加载中...</view>

    <view wx:elif="{{messages.length === 0 && emptyText}}" class="im-state-text">{{emptyText}}</view>

    <view wx:else class="im-message-stream">
      <block wx:for="{{messageBlocks}}" wx:key="key" wx:for-item="blockItem">
        <view wx:if="{{blockItem.type === 'divider'}}" class="im-divider">
          <view class="im-divider-line"></view>
          <text class="im-divider-text">{{blockItem.timeText}}</text>
          <view class="im-divider-line"></view>
        </view>

        <view wx:elif="{{blockItem.type === 'system-notice'}}" class="im-system-notice">
          <text class="im-system-notice-text">{{blockItem.text}}</text>
        </view>

        <view wx:elif="{{blockItem.type === 'cluster'}}" class="im-cluster {{blockItem.isSelf ? 'im-cluster-self' : ''}}">
          <retro-avatar
            class="im-avatar u-avatar-top"
            size="medium"
            shape="square"
            image="{{blockItem.senderAvatar}}"
            data-user-id="{{blockItem.senderId}}"
            data-user-name="{{blockItem.senderName}}"
            data-is-self="{{blockItem.isSelf ? 1 : 0}}"
            bindlongpress="onLongPressUserMeta"
            bindtap="onTapUserElement">
            {{blockItem.senderInitial}}
          </retro-avatar>

          <view class="im-message-col">
            <view
              class="im-meta-col"
              data-user-id="{{blockItem.senderId}}"
              data-user-name="{{blockItem.senderName}}"
              data-is-self="{{blockItem.isSelf ? 1 : 0}}"
              bindlongpress="onLongPressUserMeta">
              <view class="im-name-line">
                <view
                  wx:if="{{blockItem.isSelf && blockItem.senderTitleName}}"
                  class="im-title-badge u-title-badge retro-title-badge retro-title-badge-md"
                  style="{{blockItem.senderTitleColor ? 'color:' + blockItem.senderTitleColor + ';' : ''}}">
                  [{{blockItem.senderTitleName}}]
                </view>
                <view
                  class="im-name u-name {{blockItem.isSelf ? 'im-name-self' : 'im-name-peer'}}"
                  data-user-id="{{blockItem.senderId}}"
                  bindtap="onTapUserElement">
                  {{blockItem.senderName}}
                </view>
                <view
                  wx:if="{{!blockItem.isSelf && blockItem.senderTitleName}}"
                  class="im-title-badge u-title-badge retro-title-badge retro-title-badge-md"
                  style="{{blockItem.senderTitleColor ? 'color:' + blockItem.senderTitleColor + ';' : ''}}">
                  [{{blockItem.senderTitleName}}]
                </view>
              </view>
              <view class="im-time-line">
                <view class="im-meta-time">{{blockItem.headerTimeText}}</view>
              </view>
            </view>

            <view
              wx:for="{{blockItem.rows}}"
              wx:key="key"
              wx:for-item="lineItem"
              id="im-msg-{{lineItem.messageId}}"
              class="im-line {{highlightMessageId == lineItem.messageId ? 'is-highlighted' : ''}}"
              data-message-id="{{lineItem.messageId}}"
              data-client-msg-id="{{lineItem.clientMsgId}}"
              data-msg-type="{{lineItem.msgType}}"
              data-message-content="{{lineItem.content}}"
              data-sender-id="{{blockItem.senderId}}"
              data-sender-name="{{blockItem.senderName}}"
              data-create-time="{{lineItem.createTime}}"
              data-is-self="{{blockItem.isSelf ? 1 : 0}}"
              data-recalled="{{lineItem.recalled ? 1 : 0}}"
              data-reply-to-message-id="{{lineItem.replyToMessageId}}"
              data-reply-to-preview="{{lineItem.replyToPreview}}"
              data-copy="{{lineItem.copyContent}}"
              bindlongpress="onLongPressMessageRow">
              <view
                wx:if="{{lineItem.replyToMessageId && lineItem.replyToPreview}}"
                class="im-reply-quote {{lineItem.repliedToMe ? 'is-replied-to-me' : ''}} {{lineItem.replyTargetDisabled ? 'is-disabled' : ''}}"
                data-reply-target-id="{{lineItem.replyToMessageId}}"
                data-reply-target-disabled="{{lineItem.replyTargetDisabled ? 1 : 0}}"
                bindtap="onTapReplyQuote">
                <view class="im-reply-quote-label">{{lineItem.repliedToMe ? '回你' : '回复'}}</view>
                <view class="im-reply-quote-text">{{lineItem.replyToPreview}}</view>
              </view>
              <image
                wx:if="{{lineItem.msgType === 'IMAGE' && lineItem.mediaUrl}}"
                class="im-image"
                style="{{lineItem.imageRenderStyle}}"
                src="{{lineItem.mediaUrl}}"
                mode="aspectFit"
                lazy-load="{{true}}"
                data-url="{{lineItem.mediaUrl}}"
                bindtap="previewImage" />
              <view
                wx:elif="{{lineItem.msgType === 'VIDEO' && lineItem.isUploadPlaceholder}}"
                class="im-upload-placeholder">
                <view class="im-upload-placeholder-head">
                  <text class="im-upload-placeholder-title">{{lineItem.uploadFailed ? '视频上传失败' : '视频上传中'}}</text>
                  <text class="im-upload-placeholder-percent">{{lineItem.uploadProgress}}%</text>
                </view>
                <view class="im-upload-progress-track">
                  <view
                    class="im-upload-progress-fill {{lineItem.uploadFailed ? 'is-failed' : ''}}"
                    style="width: {{lineItem.uploadProgress}}%;"></view>
                </view>
                <text class="im-upload-placeholder-tip">{{lineItem.content}}</text>
                <view wx:if="{{lineItem.uploadFailed && blockItem.isSelf}}" class="im-failed-action-row">
                  <text class="im-failed-action" data-message-id="{{lineItem.messageId}}" data-client-msg-id="{{lineItem.clientMsgId}}" catchtap="onResendFailedMessage">重新发送</text>
                  <text class="im-failed-action is-danger" data-message-id="{{lineItem.messageId}}" data-client-msg-id="{{lineItem.clientMsgId}}" catchtap="onDeleteFailedMessage">删除</text>
                </view>
              </view>
              <video
                wx:elif="{{lineItem.msgType === 'VIDEO' && lineItem.mediaUrl}}"
                class="im-video-player"
                style="{{lineItem.videoRenderStyle}}"
                src="{{lineItem.mediaUrl}}"
                poster="{{lineItem.mediaPosterUrl}}"
                controls="{{true}}"
                autoplay="{{false}}"
                show-center-play-btn="{{true}}"
                show-play-btn="{{true}}"
                show-fullscreen-btn="{{true}}"
                enable-progress-gesture="{{true}}"
                object-fit="contain"
                data-message-id="{{lineItem.messageId}}"
                bindloadedmetadata="onMessageVideoLoadedMetadata"
                binderror="onMessageVideoError" />
              <text
                wx:elif="{{lineItem.msgType === 'FILE' && lineItem.mediaUrl}}"
                class="im-text im-file"
                data-url="{{lineItem.mediaUrl}}"
                data-name="{{lineItem.content}}"
                bindtap="onTapFile">{{lineItem.fileLabel}}</text>
              <text
                wx:elif="{{lineItem.msgType === 'TEXT' && lineItem.linkUrl}}"
                class="im-text im-link"
                data-url="{{lineItem.linkUrl}}"
                bindtap="onTapLink">{{lineItem.content}}</text>
              <text
                wx:elif="{{lineItem.msgType === 'RECALL'}}"
                class="im-text im-recall-text">{{lineItem.content || '该消息已撤回'}}</text>
              <text
                wx:elif="{{lineItem.msgType === 'TEXT'}}"
                class="im-text"
                user-select="{{true}}">{{lineItem.content}}</text>
              <text wx:else class="im-media-missing">[媒体不可用]</text>
              <view
                wx:if="{{lineItem.deliveryFailed && blockItem.isSelf && !(lineItem.msgType === 'VIDEO' && lineItem.isUploadPlaceholder)}}"
                class="im-send-failed-card">
                <view class="im-upload-placeholder-head">
                  <text class="im-upload-placeholder-title">{{lineItem.msgType === 'IMAGE' ? '图片发送失败' : (lineItem.msgType === 'VIDEO' ? '视频发送失败' : (lineItem.msgType === 'FILE' ? '文件发送失败' : '消息发送失败'))}}</text>
                  <text class="im-upload-placeholder-percent">100%</text>
                </view>
                <view class="im-upload-progress-track">
                  <view class="im-upload-progress-fill is-failed" style="width: 100%;"></view>
                </view>
                <text class="im-upload-placeholder-tip">{{lineItem.failTipText || '网络异常，请稍后重试'}}</text>
                <view class="im-failed-action-row">
                  <text class="im-failed-action" data-message-id="{{lineItem.messageId}}" data-client-msg-id="{{lineItem.clientMsgId}}" catchtap="onResendFailedMessage">重新发送</text>
                  <text class="im-failed-action is-danger" data-message-id="{{lineItem.messageId}}" data-client-msg-id="{{lineItem.clientMsgId}}" catchtap="onDeleteFailedMessage">删除</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>
      <view id="im-bottom-anchor" class="im-bottom-anchor"></view>
    </view>
  </scroll-view>

  <view id="im-dock" class="im-dock" style="bottom: {{keyboardHeightPx}}px;">
    <view id="im-composer" class="im-composer {{(morePanelVisible || emojiPanelVisible) ? 'is-panel-open' : ''}} {{keyboardHeightPx > 0 ? 'is-keyboard-open' : ''}}">
      <view wx:if="{{replyDraft && replyDraft.messageId}}" class="im-reply-draft">
        <text class="im-reply-draft-label">回复</text>
        <text class="im-reply-draft-content">{{replyDraft.preview || '[消息]'}}</text>
        <text class="im-reply-draft-close" bindtap="onClearReplyDraft">×</text>
      </view>
      <view class="im-composer-main-row">
        <view class="im-emoji-trigger" bindtap="onToggleEmojiPanel">
          <image class="im-emoji-icon" src="/images/icon-kaomoji.svg" mode="aspectFit" />
        </view>
        <input
          class="im-composer-input"
          type="text"
          placeholder="{{inputPlaceholder}}"
          placeholder-class="im-composer-input-placeholder"
          value="{{inputMessage}}"
          focus="{{composerFocused}}"
          adjust-position="{{false}}"
          hold-keyboard="{{true}}"
          confirm-hold="{{true}}"
          bindkeyboardheightchange="onKeyboardHeightChange"
          bindfocus="onComposerFocus"
          bindblur="onComposerBlur"
          bindinput="onMessageInput"
          confirm-type="send"
          bindconfirm="sendMessage"
        />

        <view class="im-composer-actions">
          <retro-button
            class="im-more-btn"
            size="medium"
            theme="default"
            disabled="{{sending}}"
            bindtap="onClickMore">
            更多
          </retro-button>
          <retro-button
            class="im-send-btn"
            size="medium"
            theme="primary"
            disabled="{{sending || !canSendText}}"
            loading="{{sending}}"
            bindtap="onSendButtonTap">
            发送
          </retro-button>
        </view>
      </view>
    </view>

    <view wx:if="{{emojiPanelVisible}}" class="im-emoji-panel">
      <scroll-view class="im-emoji-scroll" scroll-y enhanced="{{true}}" show-scrollbar="{{false}}">
        <view class="im-emoji-grid">
          <view
            wx:for="{{emojiList}}"
            wx:key="*this"
            class="im-emoji-item"
            data-emoji="{{item}}"
            bindtap="onSelectEmoji">
            <text class="im-emoji-item-text">{{item}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view wx:if="{{morePanelVisible}}" class="im-more-panel">
      <view class="im-more-title">更多功能</view>
      <view class="im-more-grid">
        <view
          wx:for="{{moreActions}}"
          wx:key="key"
          class="im-more-item {{item.disabled ? 'is-disabled' : ''}}"
          data-key="{{item.key}}"
          bindtap="onMoreActionTap">
          <view class="im-more-item-icon">{{item.icon || '+'}}</view>
          <view class="im-more-item-label">{{item.label}}</view>
          <view wx:if="{{item.subLabel}}" class="im-more-item-sub">{{item.subLabel}}</view>
        </view>
      </view>
    </view>
  </view>
</template>
