  --retro-tab-divider: #b8c5d7;
  --retro-theme-item-bg: #f8fbff;
  --retro-theme-item-border: #aebbd0;
  --retro-theme-item-active-bg: #e7effb;
  --retro-theme-item-active-border: #6284b3;
  --retro-divider-bg: #e3ebf8;
  --retro-divider-border: #a8b5c8;
  --retro-divider-text: #576b85;
  --retro-record-peer-bg: #f9fbff;
