@import "./styles/title-badge.wxss";
@import "./styles/user-identity.wxss";

page {
  background-color: #dce4ef;
  color: #1f2d3d;
}

.u-unread-blink {
  animation: retro-unread-blink 1.2s steps(1, end) infinite;
}

@keyframes retro-unread-blink {
  0% {
    opacity: 1;
  }
  50% {
    opacity: 0.3;
  }
  100% {
    opacity: 1;
  }
}

.container,
.chat-page,
.chat-detail-page,
.community-page,
.follow-page,
.post-create-page,
.post-detail-page,
.user-detail-page {
  box-sizing: border-box;
}

.theme-retro-blue,
.theme-retro-olive,
.theme-retro-amber,
.theme-retro-steel,
.theme-retro-wine {
  /* 会话列表尺寸 */
  --retro-session-row-min-height: 124rpx;
  --retro-session-row-padding-x: 14rpx;
  --retro-session-pin-width: 8rpx;
  --retro-session-inline-gap: 10rpx;
  --retro-session-user-width: 52%;
  --retro-session-name-font-size: 26rpx;
  --retro-session-unread-font-size: 21rpx;
  --retro-session-presence-font-size: 22rpx;
  --retro-session-preview-font-size: 21rpx;
  --retro-session-time-font-size: 21rpx;
  --retro-session-time-width: 130rpx;

  /* 聊天详情尺寸 */
  --retro-chat-row-gap: 10rpx;
  --retro-chat-meta-height: 74rpx;
  --retro-chat-name-font-size: 28rpx;
  --retro-chat-time-font-size: 20rpx;
  --retro-chat-text-font-size: 27rpx;
  --retro-chat-image-width: 320rpx;
  --retro-chat-video-width: 420rpx;
  --retro-chat-composer-input-height: 64rpx;
  --retro-chat-composer-btn-min-width: 92rpx;
}

