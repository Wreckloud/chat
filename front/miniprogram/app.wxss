  --retro-toolbar-top-border: #f3f7ff;
  --retro-toolbar-sub-text: #60738a;
  --retro-link-text: #2f5c9b;
  --retro-accent-text: #2f5c9b;
  --retro-muted-text: #62758d;
  --retro-muted-text-2: #4d6078;
  --retro-body-text: #304459;
  --retro-strong-text: #1c2b3b;
  --retro-avatar-border: #8c9caf;
  --retro-row-border: #c8d2e1;
  --retro-row-even-bg: #f7faff;
  --retro-row-pinned-bg: #e6eefc;
  --retro-chip-bg: #e1ebf8;
  --retro-chip-text: #2f5c9b;
  --retro-board-head-bg: linear-gradient(180deg, #eef4ff 0%, #c6d2e4 100%);
  --retro-board-head-top-border: #f3f7ff;
  --retro-board-head-bottom-border: #8f9bb0;
