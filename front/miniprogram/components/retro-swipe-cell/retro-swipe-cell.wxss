.retro-swipe-cell {
  position: relative;
  overflow: hidden;
}

.retro-swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: stretch;
}

.retro-swipe-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  white-space: nowrap;
}

.retro-swipe-content {
  position: relative;
  z-index: 1;
  background: transparent;
}

.retro-swipe-content.with-transition {
  transition: transform 0.2s ease;
}
