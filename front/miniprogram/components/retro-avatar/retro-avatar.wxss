:host {
  display: block;
  line-height: 0;
}

.retro-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  background: var(--retro-panel-bg, #eff4fb);
  color: var(--retro-page-text, #1f2d3d);
  font-weight: 600;
  overflow: hidden;
}

.retro-avatar-image {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 0;
}

.retro-avatar-fallback {
  width: 100%;
  height: 100%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.88) 0%,
    rgba(255, 255, 255, 0.55) 100%
  );
}

.size-small {
  width: 58rpx;
  height: 58rpx;
  font-size: 24rpx;
}

.size-medium {
  width: 74rpx;
  height: 74rpx;
  font-size: 26rpx;
}

.size-large {
  width: 96rpx;
  height: 96rpx;
  font-size: 30rpx;
}

.shape-round {
  border-radius: 0;
}

.shape-square {
  border-radius: 0;
}
