.retro-loading {
  padding: 22rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: var(--retro-muted-text, #62758d);
}

.retro-loading-spinner {
  box-sizing: border-box;
  border: 4rpx solid rgba(104, 122, 142, 0.3);
  border-top-color: var(--retro-accent-text, #2f5c9b);
  border-radius: 50%;
  animation: retro-loading-spin 0.75s linear infinite;
}

.retro-loading-text {
  margin-top: 10rpx;
  font-size: 22rpx;
}

@keyframes retro-loading-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
