.u-name-line {
  display: flex;
  align-items: flex-start;
  min-width: 0;
  gap: 4rpx;
}

.u-name {
  flex: 0 1 auto;
  width: auto;
  display: inline-block;
  min-width: 0;
  max-width: 100%;
  line-height: 1.15;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.u-title-badge {
  flex-shrink: 0;
  align-self: flex-start;
  display: inline-block;
  line-height: 1.15;
}

.u-avatar-top {
  align-self: flex-start;
}
