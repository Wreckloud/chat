/* Unified topbar style for page headers */
.retro-topbar {
  display: flex;
  align-items: center;
  gap: var(--retro-topbar-gap, 14rpx);
  box-sizing: border-box;
  height: var(--retro-topbar-height, 88rpx);
  padding: 0 var(--retro-topbar-side-gap, 12rpx);
  border-top: 1rpx solid var(--retro-toolbar-top-border);
  border-bottom: 1rpx solid var(--retro-toolbar-border);
  background: var(--retro-toolbar-bg);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.retro-topbar-title {
  min-width: 0;
  font-size: 31rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  color: var(--retro-page-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.retro-topbar-meta {
  margin-left: auto;
  flex-shrink: 0;
  font-size: 21rpx;
  color: var(--retro-muted-text-2);
  white-space: nowrap;
}
