page {
  height: 100%;
  overflow: hidden;
}

.im-page {
  position: relative;
  height: 100%;
  min-height: 0;
  overflow: hidden;
  background: var(--retro-page-bg);
  color: var(--retro-page-text);
}

.im-message-list {
  position: absolute;
  left: 0;
  right: 0;
  top: var(--im-message-list-top, 82rpx);
  bottom: 88px;
  min-height: 0;
  box-sizing: border-box;
  padding: 0 12rpx 0;
}

.im-state-text {
  margin-top: 80rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--retro-muted-text);
}

.im-message-stream {
  padding-bottom: 12rpx;
}

.im-divider {
  margin: 14rpx 0 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.im-divider-line {
  flex: 1;
  height: 1rpx;
  background: var(--retro-tab-divider);
}

.im-divider-text {
  flex-shrink: 0;
  font-size: 19rpx;
  color: var(--retro-muted-text);
}

.im-system-notice {
  margin: 2rpx 0;
  padding: 0;
  border: 0;
  background: transparent;
  text-align: center;
}

.im-system-notice-text {
  font-size: 20rpx;
  line-height: 1.3;
  color: var(--retro-divider-text);
}

.im-cluster {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.im-cluster-self {
  flex-direction: row-reverse;
}

.im-avatar {
  display: block;
  line-height: 0;
  flex-shrink: 0;
}

.im-message-col {
  flex: 0 1 auto;
  min-width: 0;
  max-width: 560rpx;
  margin-left: 12rpx;
  display: flex;
  flex-direction: column;
}

.im-cluster-self .im-message-col {
  margin-left: 0;
  margin-right: 12rpx;
  align-items: flex-end;
}

.im-meta-col {
  width: 100%;
  height: var(--retro-chat-meta-height);
  min-height: var(--retro-chat-meta-height);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.im-name-line,
.im-time-line {
  width: 100%;
  display: flex;
  min-width: 0;
}

.im-name-line {
  align-items: flex-start;
  gap: 4rpx;
}

.im-time-line {
  align-items: flex-end;
}

.im-name {
  max-width: 360rpx;
  font-size: var(--retro-session-name-font-size);
  line-height: 1.15;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.im-title-badge {
  max-width: 132rpx;
  align-self: flex-start;
  font-size: 19rpx;
  line-height: 1.15;
  margin-top: 1rpx;
}

.im-name-peer {
  color: var(--retro-strong-text);
}

.im-name-self {
  color: var(--retro-strong-text);
  text-align: right;
}

.im-cluster-self .im-title-badge {
  margin-left: 0;
}

.im-meta-time {
  font-size: var(--retro-session-presence-font-size);
  line-height: 1.2;
  color: var(--retro-muted-text-2);
  width: auto;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.im-cluster-self .im-meta-col {
  text-align: right;
}

.im-cluster-self .im-name-line,
.im-cluster-self .im-time-line {
  justify-content: flex-end;
}

.im-line {
  margin-top: 5rpx;
  width: 100%;
}

.im-line:first-of-type {
  margin-top: 4rpx;
}

.im-cluster-self .im-line {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: flex-start;
}

.im-reply-quote {
  margin-bottom: 6rpx;
  padding: 8rpx 10rpx;
  border: 0;
  border-left: 4rpx solid var(--retro-theme-item-active-border);
  background: var(--retro-theme-item-active-bg, rgba(227, 238, 249, 0.86));
  box-sizing: border-box;
  max-width: 500rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2rpx;
}

.im-cluster-self .im-reply-quote {
  border-left: 0;
  border-right: 4rpx solid var(--retro-theme-item-active-border);
  align-items: flex-end;
  text-align: right;
}

.im-reply-quote.is-replied-to-me {
  border-left-color: var(--retro-accent-color);
  background: var(--retro-theme-item-active-bg, rgba(227, 238, 249, 0.86));
}

.im-cluster-self .im-reply-quote.is-replied-to-me {
  border-right-color: var(--retro-accent-color);
}

.im-reply-quote.is-disabled {
  opacity: 0.86;
}

.im-cluster-self .im-reply-quote-label,
.im-cluster-self .im-reply-quote-text {
  text-align: right;
}

.im-reply-quote-label {
  display: block;
  width: 100%;
  font-size: 20rpx;
  line-height: 1.35;
  color: var(--retro-muted-text-2);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.im-reply-quote-text {
  display: block;
  width: 100%;
  font-size: var(--retro-chat-text-font-size);
  line-height: 1.5;
  color: var(--retro-record-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.im-text {
  display: block;
  max-width: 500rpx;
  font-size: var(--retro-chat-text-font-size);
  line-height: 1.5;
  word-break: break-all;
  color: var(--retro-record-text);
}

.im-cluster-self .im-text {
  text-align: right;
}

.im-link {
  color: var(--retro-link-text);
  text-decoration: underline;
  margin: 0;
  padding: 0;
  border: 0;
}

.im-file {
  color: var(--retro-link-text);
  text-decoration: underline;
}

.im-recall-text {
  color: var(--retro-muted-text-2);
}

.im-image {
  display: block;
  width: var(--retro-chat-image-width);
  border: 1rpx solid var(--retro-avatar-border);
  background: var(--retro-theme-item-bg);
  box-shadow: var(--retro-panel-shadow);
}

.im-video-player {
  display: block;
  width: var(--retro-chat-video-width);
  height: 236rpx;
  border: 1rpx solid var(--retro-avatar-border);
  background: var(--retro-theme-item-bg);
  box-shadow: var(--retro-panel-shadow);
  box-sizing: border-box;
}

.im-upload-placeholder {
  width: var(--retro-chat-video-width);
  max-width: 500rpx;
  padding: 12rpx 12rpx 10rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-theme-item-bg);
  box-shadow: var(--retro-panel-shadow);
  box-sizing: border-box;
}

.im-upload-placeholder-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.im-upload-placeholder-title {
  font-size: 23rpx;
  line-height: 1.2;
  color: var(--retro-strong-text);
}

.im-upload-placeholder-percent {
  font-size: 22rpx;
  line-height: 1.2;
  color: var(--retro-link-text);
}

.im-upload-progress-track {
  position: relative;
  width: 100%;
  height: 10rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-page-bg);
  overflow: hidden;
}

.im-upload-progress-fill {
  height: 100%;
  background: var(--retro-link-text);
}

.im-upload-progress-fill.is-failed {
  background: var(--retro-danger-color, #a9585d);
}

.im-upload-placeholder-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.3;
  color: var(--retro-muted-text-2);
}

.im-media-missing {
  display: block;
  font-size: var(--retro-chat-text-font-size);
  line-height: 1.5;
  color: var(--retro-muted-text);
}

.im-send-failed {
  display: block;
  margin-top: 2rpx;
  font-size: 19rpx;
  line-height: 1.25;
  color: var(--retro-danger-color, #a9585d);
}

.im-dock {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  flex-direction: column;
}

.im-composer {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: var(--retro-chat-row-gap);
  padding: 10rpx 18rpx calc(10rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--retro-composer-border);
  background: var(--retro-composer-bg);
  box-shadow: var(--retro-toolbar-shadow, inset 0 1rpx 0 rgba(255, 255, 255, 0.7));
}

.im-composer.is-panel-open {
  padding-top: 10rpx;
  padding-bottom: 10rpx;
  gap: 4rpx;
}

.im-composer.is-keyboard-open {
  padding-bottom: 10rpx;
}

.im-composer-main-row {
  --im-compose-height: var(--retro-chat-composer-input-height);
  --im-compose-icon-size: 30rpx;
  display: flex;
  align-items: center;
  gap: var(--retro-chat-row-gap);
}

.im-emoji-trigger {
  width: var(--im-compose-height);
  height: var(--im-compose-height);
  flex-shrink: 0;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-theme-item-bg);
  box-shadow: var(--retro-input-inner-shadow, inset 0 1rpx 0 rgba(255, 255, 255, 0.82));
  display: flex;
  align-items: center;
  justify-content: center;
}

.im-emoji-icon {
  width: var(--im-compose-icon-size);
  height: var(--im-compose-icon-size);
}

.im-reply-draft {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  padding: 6rpx 10rpx;
  border: 1rpx solid var(--retro-divider-border);
  background: var(--retro-divider-bg);
}

.im-reply-draft-label {
  flex-shrink: 0;
  font-size: 21rpx;
  line-height: 1.3;
  color: var(--retro-link-text);
}

.im-reply-draft-content {
  flex: 1;
  min-width: 0;
  font-size: 21rpx;
  line-height: 1.3;
  color: var(--retro-body-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.im-reply-draft-close {
  flex-shrink: 0;
  font-size: 23rpx;
  line-height: 1.2;
  color: var(--retro-muted-text-2);
}

.im-composer-input {
  flex: 1;
  height: var(--retro-chat-composer-input-height);
  box-sizing: border-box;
  padding: 0 18rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-theme-item-bg);
  color: var(--retro-page-text);
  font-size: 25rpx;
  box-shadow: var(--retro-input-inner-shadow, inset 0 1rpx 0 rgba(255, 255, 255, 0.82));
}

.im-composer-input-placeholder {
  color: var(--retro-muted-text);
}

.im-composer-actions {
  display: flex;
  align-items: center;
  gap: var(--retro-chat-row-gap);
}

.im-more-btn {
  min-width: var(--retro-chat-composer-btn-min-width);
}

.im-send-btn {
  min-width: var(--retro-chat-composer-btn-min-width);
}

.im-more-panel {
  padding: 12rpx 12rpx calc(12rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--retro-composer-border);
  background: var(--retro-composer-bg);
}

.im-emoji-panel {
  padding: 0;
  border: 0;
  background: var(--retro-composer-bg);
  overflow: hidden;
}

.im-emoji-scroll {
  height: calc(376rpx + env(safe-area-inset-bottom));
  padding: 10rpx 12rpx 10rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.im-emoji-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8rpx;
  align-content: start;
}

.im-emoji-item {
  height: 56rpx;
  padding: 8rpx 10rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
  display: flex;
  align-items: center;
  justify-content: center;
}

.im-emoji-item-text {
  max-width: 100%;
  font-size: 20rpx;
  line-height: 1.2;
  color: var(--retro-strong-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.im-more-title {
  margin-bottom: 10rpx;
  text-align: center;
  font-size: 23rpx;
  color: var(--retro-composer-label-text);
}

.im-more-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
}

.im-more-item {
  min-height: 112rpx;
  padding: 12rpx 10rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-panel-bg);
  box-shadow: var(--retro-panel-shadow);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.im-more-item.is-disabled {
  opacity: 0.52;
}

.im-more-item-icon {
  width: 38rpx;
  height: 38rpx;
  border: 1rpx solid var(--retro-panel-border);
  background: var(--retro-theme-item-active-bg);
  color: var(--retro-link-text);
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.im-more-item-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.2;
  color: var(--retro-strong-text);
}

.im-more-item-sub {
  margin-top: 4rpx;
  font-size: 19rpx;
  line-height: 1.2;
  color: var(--retro-muted-text);
}

.im-bottom-anchor {
  height: 1rpx;
}

.im-line.is-highlighted {
  background: rgba(99, 142, 196, 0.15);
}
